@startuml UniversityManagementSystem
' University Management System — Full UML Class Diagram
' Clean Architecture: Presentation → Application → Domain ← Infrastructure

left to right direction

skinparam monochrome false
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam nodesep 35
skinparam ranksep 60
skinparam packageStyle rectangle
skinparam defaultFontName "Arial"
skinparam defaultFontSize 10

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #8B949E
  FontColor #24292F
  HeaderBackgroundColor #F6F8FA
  AttributeFontColor #57606A
  StereotypeFontColor #0969DA
  ArrowColor #57606A
}
skinparam interface {
  BackgroundColor #DDF4FF
  BorderColor #0969DA
  FontColor #0550AE
  StereotypeFontColor #0969DA
}
skinparam abstract {
  BackgroundColor #FFF8C5
  BorderColor #9A6700
  FontColor #7D4E00
  StereotypeFontColor #9A6700
}
skinparam enum {
  BackgroundColor #DAFBE1
  BorderColor #1A7F37
  FontColor #116329
  StereotypeFontColor #1A7F37
}
skinparam package {
  BackgroundColor #F6F8FA
  BorderColor #D0D7DE
  FontStyle bold
  FontColor #24292F
}

' ════════════════════════════════════════════════════════════
'  COLUMN 1 — PRESENTATION · CLI  (src/presentation)
' ════════════════════════════════════════════════════════════

package "Presentation · CLI" {

  package "console" {
    interface Console {
      +println(line : String) : void
      +print(text : String) : void
      +readLine(prompt : String) : String
      +readInt(prompt : String) : int
    }
    class StdConsole implements Console {
      +println(line : String) : void
      +print(text : String) : void
      +readLine(prompt : String) : String
      +readInt(prompt : String) : int
    }
  }

  package "auth" {
    class LoginScreen {
      -users : UserRepository
      -hasher : PasswordHasher
      -console : Console
      +run() : Optional<User>
    }
  }

  package "menu" {
    interface Menu {
      +run() : void
    }
    class MenuItem {
      +label : String
      +action : Runnable
    }
    interface MenuFactory {
      +menuFor(user : User) : Menu
    }
    class BecomeResearcherAction {
      -ctx : AppContext
      +run(rc : ResearcherCapable) : void
    }
    class ResearcherMenuExtension {
      -ctx : AppContext
      +items(rc : ResearcherCapable) : List<MenuItem>
    }
  }

  package "role menus" {
    class AdminMenu {
      -ctx : AppContext
      +run() : void
    }
    class StudentMenu {
      -ctx : AppContext
      +run() : void
    }
    class GraduateStudentMenu {
      -ctx : AppContext
      +run() : void
    }
    class TeacherMenu {
      -ctx : AppContext
      +run() : void
    }
    class DeanMenu {
      -ctx : AppContext
      +run() : void
    }
    class ManagerMenu {
      -ctx : AppContext
      +run() : void
    }
    class LibrarianMenu {
      -ctx : AppContext
      +run() : void
    }
    class TechSupportMenu {
      -ctx : AppContext
      +run() : void
    }
    class EmployeeResearcherMenu {
      -ctx : AppContext
      +run() : void
    }
  }
}

' ════════════════════════════════════════════════════════════
'  COLUMN 1b — BOOTSTRAP  (src/bootstrap)
' ════════════════════════════════════════════════════════════

package "Bootstrap" {
  class AppContext {
    +console : Console
    +loginScreen : LoginScreen
    +menuFactory : MenuFactory
    +users : UserRepository
    +courses : CourseRepository
    +books : BookRepository
    +messages : MessageRepository
    +news : NewsRepository
    +requests : RequestRepository
    +orders : OrderRepository
    +papers : ResearchPaperRepository
    +projects : ResearchProjectRepository
    +organizations : OrganizationRepository
    +notifications : NotificationRepository
    +logs : LogRepository
    +enrollmentService : EnrollmentService
    +paperPublisher : PaperPublisher
    +gpaCalculator : GpaCalculator
    +hIndexCalculator : HIndexCalculator
    +citationFormatter : CitationFormatter
    +roomScheduler : RoomScheduler
    +subscriptionService : SubscriptionService
    +{static} withJsonStorage(dataDir : Path) : AppContext
  }
  class DataSeeder {
    -ctx : AppContext
    +seedIfEmpty() : void
  }
  class DefaultMenuFactory implements MenuFactory {
    -ctx : AppContext
    +menuFor(user : User) : Menu
  }
  class IdSequenceWarmup {
    +{static} warm(ctx : AppContext) : void
  }
}

' ════════════════════════════════════════════════════════════
'  COLUMN 2 — APPLICATION USE CASES  (src/application)
' ════════════════════════════════════════════════════════════

package "Application · Use Cases" {

  class "Result<T>" as Result {
    -value : T
    -error : String
    -success : boolean
    +{static} ok(value : T) : Result<T>
    +{static} fail(error : String) : Result<T>
    +isOk() : boolean
    +value() : T
    +error() : String
  }

  package "admin" {
    class CreateStudent {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,DegreeType,int) : Result<Student>
    }
    class CreateTeacher {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String,String,TeacherPosition) : Result<Teacher>
    }
    class CreateGradStudent {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,DegreeType,int) : Result<GraduateStudent>
    }
    class CreateDean {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String,String) : Result<Dean>
    }
    class CreateManager {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String,ManagerPosition) : Result<Manager>
    }
    class CreateLibrarian {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String) : Result<Librarian>
    }
    class CreateTechSupport {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String) : Result<TechSupport>
    }
    class CreateEmpResearcher {
      -users : UserRepository
      -log : LogRepository
      +execute(Username,String,PersonName,Gender,LocalDate,Email,Faculty,Money,LocalDate,String,String) : Result<EmployeeResearcher>
    }
    class DeleteUser {
      -users : UserRepository
      -log : LogRepository
      +execute(actor : Username, target : Username) : Result<Void>
    }
    class GenerateAcademicReport {
      -users : UserRepository
      -courses : CourseRepository
      -gpa : GpaCalculator
      +execute() : String
    }
    class GenerateTopResearcherNews {
      -users : UserRepository
      -papers : ResearchPaperRepository
      -news : NewsRepository
      -hIndex : HIndexCalculator
      +execute() : void
    }
  }

  package "course" {
    class EnrollInCourse {
      -users : UserRepository
      -courses : CourseRepository
      -enrollment : EnrollmentService
      -log : LogRepository
      +execute(student : Username, course : CourseId) : Result<Void>
    }
    class DropCourse {
      -users : UserRepository
      -courses : CourseRepository
      -log : LogRepository
      +execute(student : Username, course : CourseId) : Result<Void>
    }
    class RecordMarks {
      -users : UserRepository
      -courses : CourseRepository
      -log : LogRepository
      +execute(teacher : Username, course : CourseId, student : Username, att1 : int, att2 : int, exam : int) : Result<Void>
    }
    class AssignTeacher {
      -users : UserRepository
      -courses : CourseRepository
      -log : LogRepository
      +execute(teacher : Username, course : CourseId) : Result<Void>
    }
    class CreateCourse {
      -courses : CourseRepository
      -sequence : IdSequence
      -log : LogRepository
      +execute(name : String, credits : int, type : DisciplineType, capacity : int) : Result<Course>
    }
    class SetCourseCapacity {
      -courses : CourseRepository
      +execute(course : CourseId, max : int) : Result<Void>
    }
    class SetCoursePrerequisite {
      -courses : CourseRepository
      +execute(course : CourseId, prereq : CourseId) : Result<Void>
    }
    class AddLesson {
      -courses : CourseRepository
      -scheduler : RoomScheduler
      +execute(course : CourseId, type : LessonType, day : WeekDay, time : String, room : String) : Result<Void>
    }
    class ViewTranscript {
      -users : UserRepository
      -courses : CourseRepository
      -gpa : GpaCalculator
      +execute(student : Username) : String
    }
  }

  package "library" {
    class BorrowBook {
      -books : BookRepository
      -users : UserRepository
      -log : LogRepository
      +execute(borrower : Username, title : String) : Result<Void>
    }
    class ReturnBook {
      -books : BookRepository
      -log : LogRepository
      +execute(borrower : Username, book : BookId) : Result<Void>
    }
    class AddBook {
      -books : BookRepository
      -sequence : IdSequence
      +execute(title : String, author : String) : Result<Book>
    }
    class RemoveBook {
      -books : BookRepository
      +execute(book : BookId) : Result<Void>
    }
  }

  package "messaging" {
    class SendMessage {
      -messages : MessageRepository
      -users : UserRepository
      -sequence : IdSequence
      +execute(from : Username, to : Username, subject : String, body : String, urgency : UrgencyLevel) : Result<Void>
    }
    class PublishNews {
      -news : NewsRepository
      -sequence : IdSequence
      -log : LogRepository
      +execute(author : Username, title : String, body : String) : Result<Void>
    }
    class CommentOnNews {
      -news : NewsRepository
      +execute(newsId : int, comment : String) : Result<Void>
    }
    class SubmitRequest {
      -requests : RequestRepository
      -sequence : IdSequence
      +execute(requester : Username, type : HelpType, faculty : Faculty, urgency : UrgencyLevel, info : String) : Result<Void>
    }
    class ProcessRequest {
      -requests : RequestRepository
      -users : UserRepository
      +execute(requestId : int, status : RequestStatus) : Result<Void>
    }
    class CreateITOrder {
      -orders : OrderRepository
      -sequence : IdSequence
      +execute(requester : Username, description : String) : Result<Void>
    }
    class AcceptOrder {
      -orders : OrderRepository
      -log : LogRepository
      +execute(executor : Username, orderId : int) : Result<Void>
    }
    class CompleteOrder {
      -orders : OrderRepository
      -log : LogRepository
      +execute(executor : Username, orderId : int) : Result<Void>
    }
  }

  package "organization" {
    class CreateOrganization {
      -organizations : OrganizationRepository
      -users : UserRepository
      -log : LogRepository
      +execute(head : Username, name : String) : Result<Organization>
    }
    class JoinOrganization {
      -organizations : OrganizationRepository
      -log : LogRepository
      +execute(member : Username, orgName : String) : Result<Void>
    }
  }

  package "research" {
    class CreateResearchProject {
      -projects : ResearchProjectRepository
      -users : UserRepository
      -sequence : IdSequence
      -log : LogRepository
      +execute(supervisor : Username, journal : String, topic : String) : Result<ResearchProject>
    }
    class JoinResearchProject {
      -projects : ResearchProjectRepository
      -users : UserRepository
      +execute(participant : Username, journal : String) : Result<Void>
    }
    class PublishPaper {
      -publisher : PaperPublisher
      -users : UserRepository
      -sequence : IdSequence
      +execute(author : Username, title : String, journal : String, pages : int, doi : String) : Result<ResearchPaper>
    }
    class SubscribeToJournal {
      -subscription : SubscriptionService
      -users : UserRepository
      +execute(researcher : Username, journal : String) : Result<Void>
    }
    class UnsubscribeFromJournal {
      -subscription : SubscriptionService
      -users : UserRepository
      +execute(researcher : Username, journal : String) : Result<Void>
    }
    class GenerateCitation {
      -papers : ResearchPaperRepository
      -formatter : CitationFormatter
      +execute(paperId : PaperId, format : PaperFormat) : Result<String>
    }
    class SetSupervisor {
      -users : UserRepository
      -projects : ResearchProjectRepository
      -hIndex : HIndexCalculator
      -papers : ResearchPaperRepository
      +execute(supervisor : Username, gradStudent : Username) : Result<Void>
    }
  }

  package "user" {
    class BecomeResearcher {
      -users : UserRepository
      -log : LogRepository
      +execute(user : Username, field : String) : Result<Void>
    }
    class RateTeacher {
      -users : UserRepository
      -log : LogRepository
      +execute(student : Username, teacher : Username, rating : int) : Result<Void>
    }
    class ComplainAboutStudent {
      -users : UserRepository
      -messages : MessageRepository
      -sequence : IdSequence
      +execute(teacher : Username, student : Username, reason : String) : Result<Void>
    }
  }
}

' ════════════════════════════════════════════════════════════
'  COLUMN 3 — DOMAIN  (src/domain)
' ════════════════════════════════════════════════════════════

package "Domain" {

  package "capabilities" {
    interface ResearcherCapable {
      +isResearcher() : boolean
      +activateResearcher(field : String) : void
      +researcherProfile() : ResearcherProfile
    }
    interface BookBorrowerCapable
    interface PasswordHasher {
      +hash(plain : String) : String
      +matches(plain : String, hash : String) : boolean
    }
  }

  package "user" {
    abstract class User {
      -username : Username
      -passwordHash : String
      -name : PersonName
      -gender : Gender
      -dateOfBirth : LocalDate
      -email : Email
      -faculty : Faculty
      -language : Language
      +username() : Username
      +name() : PersonName
      +email() : Email
      +faculty() : Faculty
      +language() : Language
      +changePassword(newHash : String) : void
      +changeEmail(email : Email) : void
      +changeLanguage(lang : Language) : void
      +matchesPassword(hash : String) : boolean
      +equals(o : Object) : boolean
      +hashCode() : int
    }
    abstract class Employee {
      -salary : Money
      -hireDate : LocalDate
      -insuranceNumber : String
      +salary() : Money
      +hireDate() : LocalDate
      +insuranceNumber() : String
    }
    class Admin
    class Student {
      -degreeType : DegreeType
      -studyYear : int
      -availableCredits : Credits
      -failCount : int
      -enrolled : Set<CourseId>
      -completed : Set<CourseId>
      -researcherProfile : ResearcherProfile
      +{static} MAX_FAILS : int
      +degreeType() : DegreeType
      +availableCredits() : Credits
      +failCount() : int
      +hasReachedFailLimit() : boolean
      +enrolledCourses() : Set<CourseId>
      +completedCourses() : Set<CourseId>
      +recordEnrollment(id : CourseId, cost : Credits) : void
      +recordDrop(id : CourseId, refund : Credits) : void
      +recordCompletion(id : CourseId) : void
      +recordFail() : void
      +rehydrate(credits : int, fails : int, enrolled : Iterable<CourseId>, completed : Iterable<CourseId>) : void
      +isResearcher() : boolean
      +activateResearcher(field : String) : void
      +researcherProfile() : ResearcherProfile
    }
    class GraduateStudent {
      -supervisorUsername : Username
      +supervisor() : Optional<Username>
      +setSupervisor(s : Username) : void
    }
    class Teacher {
      -degree : String
      -position : TeacherPosition
      -taughtCourses : Set<CourseId>
      -ratings : List<Integer>
      -researcherProfile : ResearcherProfile
      +degree() : String
      +position() : TeacherPosition
      +setPosition(p : TeacherPosition) : void
      +taughtCourses() : Set<CourseId>
      +recordCourseAssignment(id : CourseId) : void
      +addRating(r : int) : void
      +ratings() : List<Integer>
      +averageRating() : double
      +rehydrate(courses : Iterable<CourseId>, ratings : Iterable<Integer>) : void
      +isResearcher() : boolean
      +activateResearcher(field : String) : void
      +researcherProfile() : ResearcherProfile
    }
    class Dean
    class Manager {
      -position : ManagerPosition
      +position() : ManagerPosition
    }
    class Librarian
    class TechSupport
    class EmployeeResearcher {
      -defaultField : String
      -researcherProfile : ResearcherProfile
      +defaultField() : String
      +isResearcher() : boolean
      +activateResearcher(field : String) : void
      +researcherProfile() : ResearcherProfile
    }
    class ResearcherProfile {
      -owner : Username
      -field : String
      -subscribedJournals : Set<String>
      +owner() : Username
      +field() : String
      +subscribe(journal : String) : void
      +unsubscribe(journal : String) : void
      +subscribedJournals() : Set<String>
      +isSubscribedTo(journal : String) : boolean
    }
  }

  package "course" {
    class Course {
      -id : CourseId
      -name : String
      -credits : Credits
      -type : DisciplineType
      -capacity : Capacity
      -teacherUsernames : Set<Username>
      -studentUsernames : Set<Username>
      -lessons : List<Lesson>
      -prerequisites : Set<CourseId>
      -grades : Map<Username, Grade>
      +id() : CourseId
      +credits() : Credits
      +capacity() : Capacity
      +rename(name : String) : void
      +changeCapacity(c : Capacity) : void
      +enroll(student : Username) : void
      +unenroll(student : Username) : void
      +hasStudent(student : Username) : boolean
      +students() : Set<Username>
      +isFull() : boolean
      +remainingSeats() : int
      +assignTeacher(teacher : Username) : void
      +teachers() : Set<Username>
      +addLesson(l : Lesson) : void
      +lessons() : List<Lesson>
      +addPrerequisite(p : CourseId) : void
      +prerequisites() : Set<CourseId>
      +recordGrade(student : Username, grade : Grade) : void
      +gradeOf(student : Username) : Optional<Grade>
      +allGrades() : Map<Username, Grade>
      +equals(o : Object) : boolean
      +hashCode() : int
    }
    class CourseId <<record>> {
      +value : String
      +{static} of(n : int) : CourseId
    }
    class Capacity <<record>> {
      +max : int
      +{static} UNLIMITED : Capacity
      +canFit(enrolled : int) : boolean
      +remaining(enrolled : int) : int
    }
    class Lesson <<record>> {
      +type : LessonType
      +slot : TimeSlot
      +room : Room
      +isExam() : boolean
    }
    class TimeSlot <<record>> {
      +day : WeekDay
      +time : String
      +overlaps(other : TimeSlot) : boolean
    }
    class Room <<record>> {
      +name : String
      +sameAs(other : Room) : boolean
    }
    class Grade <<record>> {
      +firstHalf : int
      +secondHalf : int
      +exam : int
      +{static} PASSING_TOTAL : int
      +total() : int
      +isPassing() : boolean
      +letter() : String
    }
  }

  package "research" {
    class ResearchPaper {
      -id : PaperId
      -title : String
      -author : Username
      -journal : JournalName
      -abstractText : String
      -pages : int
      -doi : String
      -publishedDate : LocalDate
      -citations : int
      +id() : PaperId
      +title() : String
      +author() : Username
      +journal() : JournalName
      +abstractText() : String
      +pages() : int
      +doi() : String
      +publishedDate() : LocalDate
      +citations() : int
      +cite() : void
      +length() : int
    }
    class ResearchProject {
      -id : int
      -journal : JournalName
      -topic : String
      -supervisor : Username
      -participants : Set<Username>
      -publishedPapers : List<PaperId>
      +id() : int
      +journal() : JournalName
      +topic() : String
      +supervisor() : Username
      +participants() : Set<Username>
      +publishedPapers() : List<PaperId>
      +addParticipant(u : Username) : void
      +recordPublication(id : PaperId) : void
    }
    class PaperId <<record>> {
      +value : int
    }
    class JournalName <<record>> {
      +value : String
      +matches(other : String) : boolean
    }
    class HIndex <<record>> {
      +value : int
      +{static} MIN_FOR_SUPERVISION : HIndex
      +atLeast(other : HIndex) : boolean
    }
  }

  package "library" {
    class Book {
      -id : BookId
      -title : String
      -author : String
      -borrowedBy : Username
      +id() : BookId
      +title() : String
      +author() : String
      +isBorrowed() : boolean
      +borrower() : Optional<Username>
      +lendTo(user : Username) : void
      +returnFrom(user : Username) : void
    }
    class BookId <<record>> {
      +value : int
    }
  }

  package "messaging" {
    class Message {
      -id : int
      -sender : Username
      -recipient : Username
      -subject : String
      -body : String
      -urgency : UrgencyLevel
      -sentAt : LocalDateTime
      -status : MessageStatus
      +sender() : Username
      +recipient() : Username
      +urgency() : UrgencyLevel
      +status() : MessageStatus
      +markRead() : void
      +compareTo(o : Message) : int
    }
    class News {
      -id : int
      -title : String
      -body : String
      -author : Username
      -publishedAt : LocalDateTime
      -comments : List<String>
      -pinned : boolean
      +isPinned() : boolean
      +edit(title : String, body : String) : void
      +addComment(comment : String) : void
      +compareTo(o : News) : int
    }
    class Request {
      -id : int
      -requester : Username
      -type : HelpType
      -faculty : Faculty
      -urgency : UrgencyLevel
      -additionalInfo : String
      -status : RequestStatus
      +status() : RequestStatus
      +changeStatus(s : RequestStatus) : void
    }
    class Order {
      -id : int
      -requester : Username
      -description : String
      -createdAt : LocalDate
      -status : OrderStatus
      -executor : Username
      +status() : OrderStatus
      +executor() : Optional<Username>
      +accept(executor : Username) : void
      +reject() : void
      +complete() : void
    }
    class Notification <<record>> {
      +recipient : Username
      +text : String
      +at : LocalDateTime
      +{static} of(recipient : Username, text : String) : Notification
    }
  }

  package "organization" {
    class Organization {
      -name : String
      -head : Username
      -members : Set<Username>
      +name() : String
      +head() : Username
      +members() : Set<Username>
      +isMember(u : Username) : boolean
      +addMember(u : Username) : void
    }
  }

  package "logging" {
    class LogEntry <<record>> {
      +at : LocalDateTime
      +actor : Username
      +action : String
      +{static} now(actor : Username, action : String) : LogEntry
    }
  }

  package "rules" {
    interface EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class EnrollmentDecision <<record>> {
      +allowed : boolean
      +reason : String
      +{static} allow() : EnrollmentDecision
      +{static} deny(reason : String) : EnrollmentDecision
    }
    class MaxFailLimitRule implements EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class AlreadyEnrolledRule implements EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class CreditLimitRule implements EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class CapacityRule implements EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class PrerequisiteRule implements EnrollmentRule {
      -courses : CourseRepository
      +check(student : Student, course : Course) : EnrollmentDecision
    }
    class ScheduleConflictRule implements EnrollmentRule {
      -courses : CourseRepository
      +check(student : Student, course : Course) : EnrollmentDecision
    }
  }

  package "service" {
    class EnrollmentService {
      -rules : List<EnrollmentRule>
      +tryEnroll(student : Student, course : Course) : EnrollmentDecision
    }
    class RoomScheduler {
      -courses : CourseRepository
      +isAvailable(room : Room, slot : TimeSlot) : boolean
    }
    class GpaCalculator {
      -courses : CourseRepository
      +of(student : Student) : double
    }
    class HIndexCalculator {
      +calculate(papers : List<ResearchPaper>) : HIndex
    }
    class CitationFormatter {
      +format(paper : ResearchPaper, format : PaperFormat) : String
    }
    class PaperPublisher {
      -papers : ResearchPaperRepository
      -projects : ResearchProjectRepository
      -notifications : NotificationRepository
      -news : NewsRepository
      -users : UserRepository
      +publish(paper : ResearchPaper) : void
    }
    class SubscriptionService {
      -projects : ResearchProjectRepository
      +subscribe(researcher : ResearcherCapable, journal : String) : boolean
      +unsubscribe(researcher : ResearcherCapable, journal : String) : void
    }
  }

  package "shared" {
    class Username {
      -value : String
      +value() : String
      +equals(o : Object) : boolean
      +hashCode() : int
    }
    class PersonName <<record>> {
      +first : String
      +last : String
      +full() : String
    }
    class Email <<record>> {
      +address : String
    }
    class Money <<record>> {
      +amount : double
    }
    class Credits <<record>> {
      +value : int
      +{static} SEMESTER_LIMIT : Credits
      +covers(required : Credits) : boolean
      +minus(other : Credits) : Credits
      +plus(other : Credits) : Credits
    }
    class IdSequence {
      -counter : AtomicInteger
      +next() : int
      +peek() : int
      +seedAtLeast(n : int) : void
    }
  }

  package "enums" {
    enum DegreeType { BACHELOR \n MASTER \n DOCTORATE }
    enum Faculty { SITE \n SEOGI \n SG \n KMA \n ISE \n BS }
    enum Gender { MALE \n FEMALE }
    enum Language { ENGLISH \n KAZAKH \n RUSSIAN }
    enum TeacherPosition { LECTOR \n SENIOR_LECTOR \n PROFESSOR }
    enum ManagerPosition { OR \n DEPARTMENT \n DEANS_OFFICE }
    enum DisciplineType { MAJOR \n MINOR \n FREE }
    enum LessonType { LECTURE \n PRACTICE \n OFFICE_HOURS \n EXAM }
    enum WeekDay { MONDAY \n TUESDAY \n WEDNESDAY \n THURSDAY \n FRIDAY \n SATURDAY \n SUNDAY }
    enum MessageStatus { UNREAD \n READ }
    enum UrgencyLevel { LOW \n MEDIUM \n HIGH }
    enum OrderStatus { NEW \n ACCEPTED \n REJECTED \n DONE }
    enum RequestStatus { PENDING \n ACCEPTED \n NOT_APPROVED \n APPROVED \n REJECTED }
    enum HelpType { TRANSCRIPT_FOR_SEMESTER \n TRANSCRIPT_FOR_YEAR \n CERTIFICATE_OF_EDUCATION \n ACADEMIC_MOBILITY \n COORDINATION_OF_DIPLOMA_TOPIC \n REQUEST_FOR_CREATING_ORGANIZATION }
    enum PaperFormat { PLAIN_TEXT \n BIBTEX }
  }

  package "repository" {
    interface UserRepository {
      +save(user : User) : void
      +findByUsername(username : Username) : Optional<User>
      +exists(username : Username) : boolean
      +delete(username : Username) : void
      +findAll() : Collection<User>
    }
    interface CourseRepository {
      +save(course : Course) : void
      +findById(id : CourseId) : Optional<Course>
      +findAll() : Collection<Course>
    }
    interface BookRepository {
      +save(book : Book) : void
      +findById(id : BookId) : Optional<Book>
      +findFirstAvailableByTitle(title : String) : Optional<Book>
      +findAll() : Collection<Book>
      +delete(id : BookId) : void
    }
    interface MessageRepository {
      +save(message : Message) : void
      +inboxOf(recipient : Username) : List<Message>
    }
    interface NewsRepository {
      +save(news : News) : void
      +findById(id : int) : Optional<News>
      +findAllSorted() : List<News>
      +delete(id : int) : void
    }
    interface RequestRepository {
      +save(request : Request) : void
      +findById(id : int) : Optional<Request>
      +findAll() : List<Request>
      +findByRequester(requester : Username) : List<Request>
    }
    interface OrderRepository {
      +save(order : Order) : void
      +findById(id : int) : Optional<Order>
      +findAll() : List<Order>
    }
    interface ResearchPaperRepository {
      +save(paper : ResearchPaper) : void
      +findById(id : PaperId) : Optional<ResearchPaper>
      +findByAuthor(author : Username) : List<ResearchPaper>
      +findAll() : Collection<ResearchPaper>
    }
    interface ResearchProjectRepository {
      +save(project : ResearchProject) : void
      +findByJournal(journal : JournalName) : Optional<ResearchProject>
      +findAll() : Collection<ResearchProject>
    }
    interface OrganizationRepository {
      +save(org : Organization) : void
      +findByName(name : String) : Optional<Organization>
      +findAll() : Collection<Organization>
    }
    interface NotificationRepository {
      +save(notification : Notification) : void
      +findFor(recipient : Username) : List<Notification>
      +clearFor(recipient : Username) : void
    }
    interface LogRepository {
      +append(entry : LogEntry) : void
      +findAll() : List<LogEntry>
      +findByActor(actor : Username) : List<LogEntry>
    }
  }
}

' ════════════════════════════════════════════════════════════
'  COLUMN 4 — INFRASTRUCTURE  (src/infrastructure)
' ════════════════════════════════════════════════════════════

package "Infrastructure" {

  package "auth" {
    class PlainPasswordHasher implements PasswordHasher {
      +hash(plain : String) : String
      +matches(plain : String, hash : String) : boolean
    }
  }

  package "i18n" {
    interface Translator {
      +get(key : String) : String
      +fmt(key : String, args : Object[]) : String
    }
    class PropertiesTranslator implements Translator {
      -bundle : ResourceBundle
      +get(key : String) : String
      +fmt(key : String, args : Object[]) : String
      +setLanguage(lang : Language) : void
    }
  }

  package "logging" {
    interface Logger {
      +log(actor : Username, action : String) : void
    }
    class RepositoryLogger implements Logger {
      -repository : LogRepository
      +log(actor : Username, action : String) : void
    }
  }

  package "persistence.json" {
    abstract class JsonValue <<sealed>> {
      +asString() : String
      +asInt() : int
      +asDouble() : double
      +asBoolean() : boolean
      +asArray() : List<JsonValue>
      +asObject() : Map<String, JsonValue>
      +isNull() : boolean
    }
    class JsonString { +value : String }
    class JsonNumber { +value : double }
    class JsonBool   { +value : boolean }
    class JsonNull
    class JsonArray  { +elements : List<JsonValue> }
    class JsonObject {
      +fields : Map<String, JsonValue>
      +get(key : String) : JsonValue
      +has(key : String) : boolean
    }
    class JsonReader {
      +{static} parse(text : String) : JsonValue
    }
    class JsonWriter {
      +{static} write(value : JsonValue) : String
    }
    class JsonObjectBuilder {
      +put(key : String, value : JsonValue) : JsonObjectBuilder
      +put(key : String, value : String) : JsonObjectBuilder
      +put(key : String, value : int) : JsonObjectBuilder
      +put(key : String, value : double) : JsonObjectBuilder
      +put(key : String, value : boolean) : JsonObjectBuilder
      +build() : JsonObject
    }
  }

  package "persistence.database" {
    interface Database {
      +readTable(name : String) : List<JsonValue>
      +writeTable(name : String, rows : List<JsonValue>) : void
    }
    class JsonFileDatabase implements Database {
      -root : Path
      +readTable(name : String) : List<JsonValue>
      +writeTable(name : String, rows : List<JsonValue>) : void
    }
  }

  package "persistence.orm" {
    interface "EntityMapper<T,ID>" as EntityMapper {
      +toJson(entity : T) : JsonValue
      +fromJson(json : JsonValue) : T
      +idOf(entity : T) : ID
      +idAsString(id : ID) : String
    }
    class "Repository<T,ID>" as Repository {
      -db : Database
      -tableName : String
      -mapper : EntityMapper<T,ID>
      +save(entity : T) : T
      +find(id : ID) : Optional<T>
      +findAll() : List<T>
      +delete(entity : T) : boolean
      +count() : int
      +select() : QueryBuilder<T,ID>
      +where(field : String, op : Op, value : Object) : QueryBuilder<T,ID>
    }
    class "QueryBuilder<T,ID>" as QueryBuilder {
      -conditions : List<Condition>
      +where(field : String, op : Op, value : Object) : QueryBuilder<T,ID>
      +whereEq(field : String, value : Object) : QueryBuilder<T,ID>
      +whereContains(field : String, value : Object) : QueryBuilder<T,ID>
      +whereMatch(predicate : Predicate<T>) : QueryBuilder<T,ID>
      +orderBy(comparator : Comparator<T>) : QueryBuilder<T,ID>
      +limit(n : int) : QueryBuilder<T,ID>
      +offset(n : int) : QueryBuilder<T,ID>
      +list() : List<T>
      +first() : Optional<T>
      +count() : int
      +deleteAll() : int
      +updateEach(consumer : Consumer<T>) : int
    }
    class Condition {
      +field : String
      +op : Op
      +value : Object
      +matches(row : JsonObject) : boolean
    }
    enum Op {
      EQ \n NEQ \n GT \n LT \n GTE \n LTE
      CONTAINS \n STARTS_WITH \n ENDS_WITH \n IN
    }
    class MapperHelpers {
      +{static} strOrNull(obj : JsonObject, key : String) : String
      +{static} intVal(obj : JsonObject, key : String) : int
      +{static} doubleVal(obj : JsonObject, key : String) : double
      +{static} boolVal(obj : JsonObject, key : String) : boolean
    }
  }

  package "persistence.mapper" {
    class UserMapper implements EntityMapper
    class CourseMapper implements EntityMapper
    class BookMapper implements EntityMapper
    class MessageMapper implements EntityMapper
    class NewsMapper implements EntityMapper
    class RequestMapper implements EntityMapper
    class OrderMapper implements EntityMapper
    class ResearchPaperMapper implements EntityMapper
    class ResearchProjectMapper implements EntityMapper
    class OrganizationMapper implements EntityMapper
    class NotificationMapper implements EntityMapper
    class LogEntryMapper implements EntityMapper
  }

  package "persistence.orm.repository" {
    class OrmUserRepository implements UserRepository {
      -repo : Repository<User, Username>
    }
    class OrmCourseRepository implements CourseRepository {
      -repo : Repository<Course, CourseId>
    }
    class OrmBookRepository implements BookRepository {
      -repo : Repository<Book, BookId>
    }
    class OrmMessageRepository implements MessageRepository {
      -repo : Repository<Message, Integer>
    }
    class OrmNewsRepository implements NewsRepository {
      -repo : Repository<News, Integer>
    }
    class OrmRequestRepository implements RequestRepository {
      -repo : Repository<Request, Integer>
    }
    class OrmOrderRepository implements OrderRepository {
      -repo : Repository<Order, Integer>
    }
    class OrmResearchPaperRepository implements ResearchPaperRepository {
      -repo : Repository<ResearchPaper, PaperId>
    }
    class OrmResearchProjectRepository implements ResearchProjectRepository {
      -repo : Repository<ResearchProject, Integer>
    }
    class OrmOrganizationRepository implements OrganizationRepository {
      -repo : Repository<Organization, String>
    }
    class OrmNotificationRepository implements NotificationRepository {
      -repo : Repository<Notification, String>
    }
    class OrmLogRepository implements LogRepository {
      -repo : Repository<LogEntry, String>
    }
  }

  package "persistence.inmemory" {
    class InMemoryUserRepository implements UserRepository {
      -store : Map<Username, User>
    }
    class InMemoryCourseRepository implements CourseRepository {
      -store : Map<CourseId, Course>
    }
    class InMemoryBookRepository implements BookRepository {
      -store : Map<BookId, Book>
    }
    class InMemoryMessageRepository implements MessageRepository {
      -store : List<Message>
    }
    class InMemoryNewsRepository implements NewsRepository {
      -store : Map<Integer, News>
    }
    class InMemoryOrderRepository implements OrderRepository {
      -store : Map<Integer, Order>
    }
    class InMemoryResearchPaperRepository implements ResearchPaperRepository {
      -store : Map<PaperId, ResearchPaper>
    }
    class InMemoryResearchProjectRepository implements ResearchProjectRepository {
      -store : Map<Integer, ResearchProject>
    }
    class InMemoryOrganizationRepository implements OrganizationRepository {
      -store : Map<String, Organization>
    }
    class InMemoryNotificationRepository implements NotificationRepository {
      -store : List<Notification>
    }
    class InMemoryLogRepository implements LogRepository {
      -store : List<LogEntry>
    }
  }
}

