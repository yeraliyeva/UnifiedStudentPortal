    %% ══════════════════════════════════════════════════════════════
    %%  RELATIONSHIPS
    %% ══════════════════════════════════════════════════════════════

    %% ── Inheritance  <|-- ────────────────────────────────────────
    User <|-- Admin
    User <|-- Student
    User <|-- Employee
    Student <|-- GraduateStudent
    Employee <|-- Teacher
    Employee <|-- Manager
    Employee <|-- Librarian
    Employee <|-- TechSupport
    Employee <|-- EmployeeResearcher
    Teacher <|-- Dean

    %% ── Interface realisations  ..|> ─────────────────────────────
    Student ..|> ResearcherCapable
    Student ..|> BookBorrowerCapable
    GraduateStudent ..|> ResearcherCapable
    Teacher ..|> ResearcherCapable
    Teacher ..|> BookBorrowerCapable
    EmployeeResearcher ..|> ResearcherCapable
    MaxFailLimitRule ..|> EnrollmentRule
    AlreadyEnrolledRule ..|> EnrollmentRule
    CreditLimitRule ..|> EnrollmentRule
    CapacityRule ..|> EnrollmentRule
    PrerequisiteRule ..|> EnrollmentRule
    ScheduleConflictRule ..|> EnrollmentRule
    StdConsole ..|> Console
    DefaultMenuFactory ..|> MenuFactory
    AdminMenu ..|> Menu
    StudentMenu ..|> Menu
    GraduateStudentMenu ..|> Menu
    TeacherMenu ..|> Menu
    DeanMenu ..|> Menu
    ManagerMenu ..|> Menu
    LibrarianMenu ..|> Menu
    TechSupportMenu ..|> Menu
    EmployeeResearcherMenu ..|> Menu
    PlainPasswordHasher ..|> PasswordHasher
    PropertiesTranslator ..|> Translator
    RepositoryLogger ..|> Logger
    JsonFileDatabase ..|> Database
    OrmUserRepository ..|> UserRepository
    OrmCourseRepository ..|> CourseRepository
    OrmBookRepository ..|> BookRepository
    OrmMessageRepository ..|> MessageRepository
    OrmNewsRepository ..|> NewsRepository
    OrmRequestRepository ..|> RequestRepository
    OrmOrderRepository ..|> OrderRepository
    OrmResearchPaperRepository ..|> ResearchPaperRepository
    OrmResearchProjectRepository ..|> ResearchProjectRepository
    OrmOrganizationRepository ..|> OrganizationRepository
    OrmNotificationRepository ..|> NotificationRepository
    OrmLogRepository ..|> LogRepository
    InMemoryUserRepository ..|> UserRepository
    InMemoryCourseRepository ..|> CourseRepository
    InMemoryBookRepository ..|> BookRepository
    InMemoryMessageRepository ..|> MessageRepository
    InMemoryNewsRepository ..|> NewsRepository
    InMemoryOrderRepository ..|> OrderRepository
    InMemoryResearchPaperRepository ..|> ResearchPaperRepository
    InMemoryResearchProjectRepository ..|> ResearchProjectRepository
    InMemoryOrganizationRepository ..|> OrganizationRepository
    InMemoryNotificationRepository ..|> NotificationRepository
    InMemoryLogRepository ..|> LogRepository
    Message ..|> Comparable
    News ..|> Comparable

    %% ── Composition  *-- (part cannot exist without whole) ───────
    User *-- Username : username
    User *-- PersonName : name
    User *-- Email : email
    Employee *-- Money : salary
    Student "0..1" *-- ResearcherProfile : researcherProfile
    Teacher "0..1" *-- ResearcherProfile : researcherProfile
    EmployeeResearcher "0..1" *-- ResearcherProfile : researcherProfile
    ResearcherProfile *-- Username : owner
    Course *-- CourseId : id
    Course *-- Credits : credits
    Course *-- Capacity : capacity
    Course "1" *-- "0..*" Lesson : lessons
    Course "1" *-- "0..*" Grade : grades
    Lesson *-- TimeSlot : slot
    Lesson *-- Room : room
    ResearchPaper *-- PaperId : id
    ResearchPaper *-- Username : author
    ResearchPaper *-- JournalName : journal
    ResearchProject *-- JournalName : journal
    ResearchProject *-- Username : supervisor
    Book *-- BookId : id
    Message *-- Username : sender
    Message *-- Username : recipient
    News *-- Username : author
    Request *-- Username : requester
    Order *-- Username : requester
    Notification *-- Username : recipient
    Organization *-- Username : head
    LogEntry *-- Username : actor

    %% ── Aggregation  o-- (part can exist independently) ──────────
    ResearchProject "1" o-- "0..*" PaperId : publishedPapers
    ResearchProject "1" o-- "0..*" Username : participants
    Organization "1" o-- "1..*" Username : members
    Student "1" o-- "0..*" CourseId : enrolled
    Student "1" o-- "0..*" CourseId : completed
    Teacher "1" o-- "0..*" CourseId : taughtCourses
    Course "1" o-- "0..*" CourseId : prerequisites
    EnrollmentService "1" o-- "1..*" EnrollmentRule : rules

    %% ── Association  --> (navigable reference) ───────────────────
    User --> Faculty : faculty
    User --> Gender : gender
    User --> Language : language
    Student --> DegreeType : degreeType
    Student --> Credits : availableCredits
    Teacher --> TeacherPosition : position
    Manager --> ManagerPosition : position
    Course --> DisciplineType : type
    Lesson --> LessonType : type
    TimeSlot --> WeekDay : day
    Message --> UrgencyLevel : urgency
    Message --> MessageStatus : status
    Request --> HelpType : type
    Request --> Faculty : faculty
    Request --> UrgencyLevel : urgency
    Request --> RequestStatus : status
    Order --> OrderStatus : status
    Order --> Username : "0..1 executor"
    Book --> Username : "0..1 borrowedBy"
    GraduateStudent --> Username : "0..1 supervisorUsername"

    %% ── Dependency  ..> (uses/calls) ─────────────────────────────
    %% Bootstrap wires the full system
    AppContext ..> UserRepository : wires
    AppContext ..> CourseRepository : wires
    AppContext ..> BookRepository : wires
    AppContext ..> MessageRepository : wires
    AppContext ..> NewsRepository : wires
    AppContext ..> RequestRepository : wires
    AppContext ..> OrderRepository : wires
    AppContext ..> ResearchPaperRepository : wires
    AppContext ..> ResearchProjectRepository : wires
    AppContext ..> OrganizationRepository : wires
    AppContext ..> NotificationRepository : wires
    AppContext ..> LogRepository : wires
    AppContext ..> EnrollmentService : wires
    AppContext ..> PaperPublisher : wires
    DefaultMenuFactory ..> AppContext : uses

    %% CLI → Application use cases
    LoginScreen ..> UserRepository : calls
    LoginScreen ..> PasswordHasher : calls
    AdminMenu ..> AppContext : calls
    StudentMenu ..> AppContext : calls
    GraduateStudentMenu ..> AppContext : calls
    TeacherMenu ..> AppContext : calls
    DeanMenu ..> AppContext : calls
    ManagerMenu ..> AppContext : calls
    LibrarianMenu ..> AppContext : calls
    TechSupportMenu ..> AppContext : calls
    EmployeeResearcherMenu ..> AppContext : calls

    %% Application Admin → repos
    CreateStudent ..> UserRepository : calls
    CreateStudent ..> LogRepository : calls
    CreateTeacher ..> UserRepository : calls
    CreateTeacher ..> LogRepository : calls
    CreateGradStudent ..> UserRepository : calls
    CreateDean ..> UserRepository : calls
    CreateManager ..> UserRepository : calls
    CreateLibrarian ..> UserRepository : calls
    CreateTechSupport ..> UserRepository : calls
    CreateEmpResearcher ..> UserRepository : calls
    DeleteUser ..> UserRepository : calls
    DeleteUser ..> LogRepository : calls
    GenerateAcademicReport ..> UserRepository : calls
    GenerateAcademicReport ..> CourseRepository : calls
    GenerateAcademicReport ..> GpaCalculator : calls
    GenerateTopResearcherNews ..> UserRepository : calls
