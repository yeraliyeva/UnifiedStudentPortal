```mermaid
flowchart LR
    %% ==========================================
    %% STYLES
    %% ==========================================
    classDef actorStud fill:#FDEBD0,stroke:#D35400,stroke-width:2px,color:#000
    classDef actorEmp  fill:#D6EAF8,stroke:#2980B9,stroke-width:2px,color:#000
    classDef actorAdm  fill:#FADBD8,stroke:#C0392B,stroke-width:2px,color:#000

    classDef uc        fill:#EAFAF1,stroke:#27AE60,stroke-width:1.5px,color:#000
    classDef ucMgmt    fill:#FDEDEC,stroke:#943126,stroke-width:1.5px,color:#000
    classDef ucRes     fill:#FEF9E7,stroke:#B7950B,stroke-width:1.5px,color:#000
    classDef event     fill:#FFF5F5,stroke:#A93226,stroke-width:1.5px,stroke-dasharray:5 5,color:#000

    classDef obj       fill:#FFFFFF,stroke:#34495E,stroke-width:2px,color:#000

    %% ==========================================
    %% ACTORS
    %% ==========================================
    Student((🎓 Student)):::actorStud
    Grad((🎓 Graduate Student)):::actorStud
    Teacher((👨‍🏫 Teacher)):::actorEmp
    EmpRes((🔬 Employee Researcher)):::actorEmp
    Manager((📊 Manager)):::actorEmp
    Librarian((📚 Librarian)):::actorEmp
    TechSup((🛠️ Tech Support)):::actorEmp
    Dean((👨‍💼 Dean)):::actorAdm
    Admin((🛡️ Admin)):::actorAdm

    %% ==========================================
    %% DOMAIN OBJECTS
    %% ==========================================
    OBJ_Course[📘 Course]:::obj
    OBJ_Lesson[📅 Lesson]:::obj
    OBJ_Marks[📝 Marks Journal]:::obj
    OBJ_Book[📖 Book]:::obj
    OBJ_Org[🏛️ Organization]:::obj
    OBJ_News[📰 News]:::obj
    OBJ_Msg[💬 Message]:::obj
    OBJ_Req[📨 Request]:::obj
    OBJ_Order[🎫 IT Order]:::obj
    OBJ_Paper[📄 Research Paper]:::obj
    OBJ_Project[🔬 Research Project]:::obj
    OBJ_UserAcc[👥 User Account]:::obj
    OBJ_Logs[📜 System Logs]:::obj

    %% ==========================================
    %% ACADEMIC: ENROLL / DROP
    %% ==========================================
    UC_Enroll(Enroll in Course):::uc
    UC_Drop(Drop Course):::uc
    EVT_Prereq((Check Prerequisites)):::event
    EVT_Limit((Check Credit Limit)):::event

    Student --> UC_Enroll
    Grad --> UC_Enroll
    UC_Enroll --> EVT_Prereq
    UC_Enroll --> EVT_Limit
    UC_Enroll --> OBJ_Course

    Student --> UC_Drop
    Grad --> UC_Drop
    UC_Drop --> OBJ_Course

    Student -->|view enrolled, view available| OBJ_Course
    Grad -->|view enrolled, view available| OBJ_Course
    Teacher -->|view taught| OBJ_Course

    %% ==========================================
    %% ACADEMIC: COURSE / LESSON MGMT
    %% ==========================================
    UC_CreateCourse(Create Course):::ucMgmt
    UC_AssignTch(Assign Teacher to Course):::ucMgmt
    UC_AddLesson(Add Lesson to Course):::ucMgmt

    Manager --> UC_CreateCourse
    Manager --> UC_AssignTch
    Manager --> UC_AddLesson

    UC_CreateCourse --> OBJ_Course
    UC_AssignTch --> OBJ_Course
    UC_AssignTch -.binds.-> Teacher
    UC_AddLesson --> OBJ_Lesson
    OBJ_Lesson -.part of.-> OBJ_Course

    Student -->|view schedule, view exams| OBJ_Lesson
    Grad -->|view schedule, view exams| OBJ_Lesson
    Teacher -->|view schedule, view office hours| OBJ_Lesson

    %% ==========================================
    %% ACADEMIC: MARKS
    %% ==========================================
    UC_PutMarks(Put / Change Marks):::uc
    EVT_RecalcGPA((Recalculate GPA)):::event

    Teacher --> UC_PutMarks
    UC_PutMarks --> OBJ_Marks
    UC_PutMarks --> EVT_RecalcGPA
    OBJ_Marks -.belongs to.-> OBJ_Course

    Student -->|view own marks, view transcript| OBJ_Marks
    Grad -->|view own marks, view transcript| OBJ_Marks
    Teacher -->|view all in course| OBJ_Marks

    %% ==========================================
    %% LIBRARY
    %% ==========================================
    UC_Borrow(Borrow Book):::uc
    UC_Return(Return Book):::uc
    UC_AddBook(Add Book):::ucMgmt
    UC_RemoveBook(Remove Book):::ucMgmt

    Student --> UC_Borrow
    Grad --> UC_Borrow
    Teacher --> UC_Borrow
    Student --> UC_Return
    Grad --> UC_Return
    Teacher --> UC_Return

    Librarian --> UC_AddBook
    Librarian --> UC_RemoveBook

    UC_Borrow --> OBJ_Book
    UC_Return --> OBJ_Book
    UC_AddBook --> OBJ_Book
    UC_RemoveBook --> OBJ_Book

    Student -->|view available| OBJ_Book
    Grad -->|view available| OBJ_Book
    Teacher -->|view available| OBJ_Book
    Librarian -->|view all with status| OBJ_Book

    %% ==========================================
    %% ORGANIZATION
    %% ==========================================
    UC_CreateOrg(Create Organization):::uc
    UC_JoinOrg(Join Organization):::uc

    Student --> UC_CreateOrg
    Grad --> UC_CreateOrg
    Student --> UC_JoinOrg
    Grad --> UC_JoinOrg

    UC_CreateOrg --> OBJ_Org
    UC_JoinOrg --> OBJ_Org

    Student -->|view| OBJ_Org
    Grad -->|view| OBJ_Org

    %% ==========================================
    %% NEWS
    %% ==========================================
    UC_AddNews(Add News):::ucMgmt
    UC_EditNews(Edit News):::ucMgmt
    UC_DelNews(Delete News):::ucMgmt
    UC_CommentNews(Comment on News):::uc

    Manager --> UC_AddNews
    Admin --> UC_AddNews
    Manager --> UC_EditNews
    Admin --> UC_EditNews
    Manager --> UC_DelNews
    Admin --> UC_DelNews

    Student --> UC_CommentNews
    Grad --> UC_CommentNews
    Teacher --> UC_CommentNews

    UC_AddNews --> OBJ_News
    UC_EditNews --> OBJ_News
    UC_DelNews --> OBJ_News
    UC_CommentNews --> OBJ_News

    Student -->|view| OBJ_News
    Grad -->|view| OBJ_News
    Teacher -->|view| OBJ_News
    EmpRes -->|view| OBJ_News
    Manager -->|view| OBJ_News
    Librarian -->|view| OBJ_News
    TechSup -->|view| OBJ_News
    Dean -->|view| OBJ_News
    Admin -->|view| OBJ_News

    %% ==========================================
    %% MESSAGE
    %% ==========================================
    UC_SendMsg(Send Message):::uc

    Student --> UC_SendMsg
    Grad --> UC_SendMsg
    Teacher --> UC_SendMsg
    EmpRes --> UC_SendMsg
    Manager --> UC_SendMsg
    Librarian --> UC_SendMsg
    TechSup --> UC_SendMsg
    Dean --> UC_SendMsg
    Admin --> UC_SendMsg

    UC_SendMsg --> OBJ_Msg

    Student -->|view inbox| OBJ_Msg
    Grad -->|view inbox| OBJ_Msg
    Teacher -->|view inbox| OBJ_Msg
    EmpRes -->|view inbox| OBJ_Msg
    Manager -->|view inbox| OBJ_Msg
    Librarian -->|view inbox| OBJ_Msg
    TechSup -->|view inbox| OBJ_Msg
    Dean -->|view inbox| OBJ_Msg
    Admin -->|view inbox| OBJ_Msg

    %% ==========================================
    %% REQUEST
    %% ==========================================
    UC_SubmitReq(Submit Request):::uc
    UC_ProcessReq(Process Request - Manager):::ucMgmt
    UC_DeanApprove(Approve Request - Dean):::ucMgmt
    EVT_RouteStatus((Send Status Message)):::event

    Student --> UC_SubmitReq
    Grad --> UC_SubmitReq
    Teacher --> UC_SubmitReq
    EmpRes --> UC_SubmitReq
    Librarian --> UC_SubmitReq

    Manager --> UC_ProcessReq
    Dean --> UC_DeanApprove

    UC_SubmitReq --> OBJ_Req
    UC_ProcessReq --> OBJ_Req
    UC_ProcessReq --> EVT_RouteStatus
    UC_DeanApprove --> OBJ_Req
    UC_DeanApprove --> EVT_RouteStatus
    EVT_RouteStatus --> OBJ_Msg

    Student -->|view own| OBJ_Req
    Grad -->|view own| OBJ_Req
    Manager -->|view filtered| OBJ_Req
    Dean -->|view incoming| OBJ_Req

    %% ==========================================
    %% IT SUPPORT ORDER
    %% ==========================================
    UC_CreateOrder(Create IT Order):::uc
    UC_AcceptOrder(Accept Order):::uc
    UC_RejectOrder(Reject Order):::uc
    UC_DoneOrder(Complete Order):::uc

    Teacher --> UC_CreateOrder
    EmpRes --> UC_CreateOrder
    Manager --> UC_CreateOrder
    Librarian --> UC_CreateOrder
    Dean --> UC_CreateOrder

    TechSup --> UC_AcceptOrder
    TechSup --> UC_RejectOrder
    TechSup --> UC_DoneOrder

    UC_CreateOrder --> OBJ_Order
    UC_AcceptOrder --> OBJ_Order
    UC_RejectOrder --> OBJ_Order
    UC_DoneOrder --> OBJ_Order
    UC_DoneOrder --> EVT_RouteStatus

    TechSup -->|view new, view own| OBJ_Order

    %% ==========================================
    %% RESEARCH
    %% ==========================================
    UC_PublishPaper(Publish Paper):::ucRes
    UC_CreateProj(Create Research Project):::ucRes
    UC_JoinProj(Join Project):::ucRes
    UC_SetSup(Set Supervisor):::ucRes
    EVT_HIndex((Recalculate H-Index)):::event
    EVT_NotifySub((Notify Subscribers)):::event
    EVT_AutoNews((Auto-Generate News)):::event

    Teacher --> UC_PublishPaper
    Grad --> UC_PublishPaper
    EmpRes --> UC_PublishPaper
    Dean --> UC_PublishPaper

    Teacher --> UC_CreateProj
    Grad --> UC_CreateProj
    EmpRes --> UC_CreateProj

    Grad --> UC_JoinProj
    Grad --> UC_SetSup

    UC_PublishPaper --> OBJ_Paper
    UC_PublishPaper --> EVT_HIndex
    UC_PublishPaper --> EVT_NotifySub
    UC_PublishPaper --> EVT_AutoNews
    EVT_NotifySub --> OBJ_Msg
    EVT_AutoNews --> OBJ_News

    UC_CreateProj --> OBJ_Project
    UC_JoinProj --> OBJ_Project
    UC_SetSup -.binds.-> Teacher

    Teacher -->|view own| OBJ_Paper
    Grad -->|view own, view diploma papers| OBJ_Paper
    EmpRes -->|view own| OBJ_Paper
    Librarian -->|notified on publish| OBJ_Paper

    Teacher -->|view own| OBJ_Project
    Grad -->|view, view participants| OBJ_Project
    EmpRes -->|view own| OBJ_Project

    %% ==========================================
    %% USER ACCOUNTS / RATING / COMPLAINT / TOP RES
    %% ==========================================
    UC_CreateUser(Create User):::ucMgmt
    UC_RemoveUser(Remove User):::ucMgmt
    UC_RateTch(Rate Teacher):::uc
    UC_Complain(Complain about Student):::uc
    UC_TopRes(Generate Top Researcher News):::ucMgmt

    Admin --> UC_CreateUser
    Admin --> UC_RemoveUser
    Admin --> UC_TopRes
    Student --> UC_RateTch
    Teacher --> UC_Complain

    UC_CreateUser --> OBJ_UserAcc
    UC_RemoveUser --> OBJ_UserAcc
    UC_RateTch -.targets.-> Teacher
    UC_Complain -.about.-> Student
    UC_Complain --> EVT_RouteStatus
    UC_TopRes --> OBJ_News
    UC_TopRes -.uses.-> OBJ_Paper

    Admin -->|view all| OBJ_UserAcc
    Manager -->|view students by GPA, view teachers| OBJ_UserAcc
    Student -->|view teacher info| OBJ_UserAcc

    %% ==========================================
    %% LOGS
    %% ==========================================
    Admin -->|view all, filter by user| OBJ_Logs
```
