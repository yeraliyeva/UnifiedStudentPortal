    %% Application Messaging
    SendMessage ..> MessageRepository : calls
    SendMessage ..> UserRepository : calls
    SendMessage ..> IdSequence : calls
    PublishNews ..> NewsRepository : calls
    PublishNews ..> IdSequence : calls
    PublishNews ..> LogRepository : calls
    CommentOnNews ..> NewsRepository : calls
    SubmitRequest ..> RequestRepository : calls
