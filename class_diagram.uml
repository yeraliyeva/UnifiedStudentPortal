@startuml
skinparam classAttributeIconSize 0
skinparam monochrome true
skinparam shadowing false

' ==========================================
' ENUMS
' ==========================================
enum Language {
    ENGLISH
    RUSSIAN
    KAZAKH
}
enum Faculty {
    SITE
    BS
    KMA
    FIT
    KBTU
}
enum Gender {
    MALE
    FEMALE
}
enum DisciplineType {
    MAJOR
    MINOR
    FREE
}
enum DegreeType {
    BACHELOR
    MASTER
    DOCTORATE
}
enum TeacherPosition {
    PROFESSOR
    LECTOR
}
enum ManagerPosition {
    OR
    DEPARTMENT
    DEANS_OFFICE
}
enum HelpType {
    TRANSCRIPT_FOR_SEMESTER
    CERTIFICATE_OF_EDUCATION
    ACADEMIC_MOBILITY
}
enum UrgencyLevel {
    LOW
    MEDIUM
    HIGH
}
enum RequestStatus {
    PENDING
    ACCEPTED
    APPROVED
    NOT_APPROVED
}
enum OrderStatus {
    NEW
    ACCEPTED
    DONE
    REJECTED
}
enum LessonType {
    LECTURE
    PRACTICE
    OFFICE_HOURS
}
enum WeekDay {
    MONDAY
    TUESDAY
}

' ==========================================
' INTERFACES
' ==========================================
interface Researcher {
    +addResearchPaper(paper: ResearchPaper): void
    +createResearchProject(project: ResearchProject): void
    +getMyPapers(): List<ResearchPaper>
    +getResearchProjects(): List<ResearchProject>
    +calculateHIndex(): int
    +printPapers(comparator: Comparator): void
}

interface Subscriber {
    +notifyNewPaper(journalName: String, paper: ResearchPaper): void
}

interface CanBorrowBook {
    +borrowBook(book: Book): void
    +returnBook(book: Book): void
}

interface Managable {
    +viewAcademicStatistics(): void
}

' ==========================================
' COMMON & DATA (Singletons/Utils)
' ==========================================
class Database << (S,#FF7700) Singleton >> {
    -{static} instance: Database
    -users: List<User>
    -courses: List<Course>
    -messages: List<Message>
    -news: List<News>
    -requests: List<Request>
    -orders: List<Order>
    -books: List<Book>
    -projects: List<ResearchProject>
    -organizations: List<Organization>
    -Database()
    +{static} getInstance(): Database
    +{static} resetInstanceForTesting(): void
    +addUser(user: User): void
    +removeUser(username: String): void
    +getUser(username: String): User
    +userExists(username: String): boolean
    +getAllUsers(): List<User>
    +getStudentsByGPA(): List<Student>
    +getTopCitedResearcher(): Researcher
    +generateTopResearcherNews(): void
}

class LogManager << (S,#FF7700) Singleton >> {
    -{static} instance: LogManager
    -logs: List<String>
    -LogManager()
    +{static} getInstance(): LogManager
    +log(username: String, action: String): void
    +getLogs(): List<String>
    +getLogsForUser(username: String): List<String>
}

class Messages {
    -{static} bundle: ResourceBundle
    +{static} setLanguage(lang: Language): void
    +{static} get(key: String): String
    +{static} fmt(key: String, args: Object...): String
}

class AppScanner {
    -{static} scanner: Scanner
    +{static} get(): Scanner
}

class DataSeeder {
    +{static} seed(): void
}

class PaperComparators {
    +{static} BY_CITATIONS: Comparator<ResearchPaper>
    +{static} BY_LENGTH: Comparator<ResearchPaper>
    +{static} BY_DATE: Comparator<ResearchPaper>
    +{static} BY_TITLE: Comparator<ResearchPaper>
}

' ==========================================
' COMMUNICATION & EDUCATION
' ==========================================
class Message {
    -id: int
    -senderUsername: String
    -recipientUsername: String
    -subject: String
    -body: String
    -sentDate: LocalDate
    -isRead: boolean
    -urgency: UrgencyLevel
    +Message(sender, recipient, subject, body, urgency)
    +markRead(): void
    +getId(): int
    +toString(): String
}

class News {
    -id: int
    -title: String
    -body: String
    -authorUsername: String
    -publishedDate: LocalDate
    -comments: List<String>
    +News(title, body, author)
    +addComment(comment: String): void
    +edit(title: String, body: String): void
    +isPinned(): boolean
    +compareTo(other: News): int
}

class Order {
    -id: int
    -requesterUsername: String
    -description: String
    -status: OrderStatus
    -executorUsername: String
    -createdDate: LocalDate
    +Order(requester, desc)
    +accept(executor: String): void
    +markDone(): void
    +reject(): void
}

class Request {
    -id: int
    -requesterUsername: String
    -type: HelpType
    -faculty: Faculty
    -urgency: UrgencyLevel
    -additionalInfo: String
    -status: RequestStatus
    -date: LocalDate
    +Request(requester, type, faculty, urgency, info)
    +setStatus(status: RequestStatus): void
}

class Organization {
    -id: int
    -name: String
    -headUsername: String
    -members: List<String>
    +Organization(name, head)
    +addMember(username: String): void
    +removeMember(username: String): void
    +isMember(username: String): boolean
}

class ResearchProject {
    -id: int
    -journalName: String
    -topic: String
    -supervisorUsername: String
    -participantUsernames: List<String>
    -publishedPapers: List<ResearchPaper>
    -subscribers: List<Subscriber>
    +addParticipant(user: Object): void
    +publishPaper(paper: ResearchPaper): void
    +subscribe(sub: Subscriber): void
    +unsubscribe(sub: Subscriber): void
    -notifySubscribers(paper: ResearchPaper): void
}

class ResearchPaper {
    -id: int
    -title: String
    -authorUsername: String
    -journalName: String
    -wording: String
    -citations: int
    -pages: int
    -doi: String
    -publishedDate: LocalDate
    -references: List<String>
    +addReference(ref: String): void
    +incrementCitations(): void
    +getCitation(format: PaperFormat): String
    +getLength(): int
}

class Course {
    -courseId: String
    -courseName: String
    -credits: int
    -type: DisciplineType
    -teachers: List<Teacher>
    -students: List<Student>
    -lessons: List<Lesson>
    -grades: Map<String, AttestationResult>
    +addTeacher(t: Teacher): void
    +enrollStudent(s: Student): void
    +removeStudent(s: Student): void
    +addLesson(l: Lesson): void
    +setGrade(username: String, att1: int, att2: int, exam: int): void
    +getGrade(username: String): AttestationResult
}

class Lesson {
    -type: LessonType
    -day: WeekDay
    -time: String
    -room: String
    +Lesson(type, day, time, room)
}

class AttestationResult {
    -firstHalf: int
    -secondHalf: int
    -exam: int
    +getTotal(): int
    +getGradeLetter(): String
    +getGradePoint(): double
}

class Book {
    -id: int
    -title: String
    -author: String
    -isBorrowed: boolean
    +setBorrowed(b: boolean): void
}

' ==========================================
' USER HIERARCHY
' ==========================================
abstract class User {
    -firstName: String
    -lastName: String
    -username: String
    -password: String
    -gender: Gender
    -dateOfBirth: LocalDate
    -email: String
    -faculty: Faculty
    -language: Language
    #{static} scanner: Scanner
    +{abstract} showMenu(): void
    +sendMessage(to, subject, body, urgency): void
    +viewInbox(): void
    +sendMessageInteractive(): void
    +submitRequest(type, urgency, info): void
    +viewMyRequests(): void
    +viewNews(): void
    +commentOnNews(): void
    +viewPersonalInfo(): void
    +editPersonalInfo(): void
    +checkPassword(pwd): boolean
    #readInt(): int
    #parseUrgency(String): UrgencyLevel
}

class Student {
    -degree: DegreeType
    -studyYear: int
    -failCount: int
    -enrolledCourses: List<Course>
    -organizations: List<Organization>
    +showMenu(): void
    +enrollCourse(Course): void
    +dropCourse(Course): void
    +viewEnrolledCourses(): void
    +viewTranscript(): void
    +rateTeacherInteractive(): void
    +viewTeacherInfoInteractive(): void
    +joinOrganizationInteractive(): void
    +createOrganizationInteractive(): void
    +viewMyOrganizations(): void
    +recordFail(): void
    +getAvailableCredits(): int
    +calculateGPA(): double
}

abstract class Employee {
    -salary: double
    -hireDate: LocalDate
    -insuranceNumber: String
    +{abstract} showMenu(): void
    +addOrder(desc: String): void
}

class Teacher {
    -degree: String
    -position: TeacherPosition
    -taughtCourses: List<Course>
    -myPapers: List<ResearchPaper>
    -myProjects: List<ResearchProject>
    -borrowedBooks: List<Book>
    -notifications: List<String>
    -ratings: List<Integer>
    +showMenu(): void
    +assignToCourse(Course): void
    +viewTaughtCourses(): void
    +putMarksInteractive(): void
    +viewStudentAttestations(): void
    +viewOfficeHoursSchedule(): void
    +sendComplaintAboutStudent(username, reason, urgency): void
    +addRating(int): void
    +getAverageRating(): double
    +addResearchPaper(ResearchPaper): void
    +createResearchProject(ResearchProject): void
    +borrowBook(Book): void
    +notifyNewPaper(String, ResearchPaper): void
}

class Dean {
    +showMenu(): void
    +viewIncomingRequests(): void
    +processRequestInteractive(): void
}

class Admin {
    +showMenu(): void
    +createStudent(...): Student
    +createTeacher(...): Teacher
    +createManager(...): Manager
    +createDean(...): Dean
    +createLibrarian(...): Librarian
    +createTechSupport(...): TechSupport
    +createEmployeeResearcher(...): EmployeeResearcher
    +viewAllUsers(): void
    +removeUser(username: String): void
    +addNewsInteractive(): void
    +viewLogs(): void
    +viewLogsForUser(): void
    +generateTopResearcherNews(): void
}

class Manager {
    -position: ManagerPosition
    +showMenu(): void
    +viewRequests(): void
    +processRequestInteractive(): void
    +createCourseInteractive(): void
    +assignTeacherToCourseInteractive(): void
    +addLessonToCourseInteractive(): void
    +addNewsInteractive(): void
    +viewAcademicStatistics(): void
    +viewStudentsByGPA(): void
}

class TechSupport {
    +showMenu(): void
    +viewNewOrders(): void
    +viewMyOrders(): void
    +processOrderInteractive(): void
    +completeOrderInteractive(): void
    +fixSystem(): void
}

class Librarian {
    +showMenu(): void
    +viewAllBooks(): void
    +addBookInteractive(): void
    +removeBookInteractive(): void
    +notifyNewPaper(String, ResearchPaper): void
}

class EmployeeResearcher {
    -researchField: String
    -myPapers: List<ResearchPaper>
    -myProjects: List<ResearchProject>
    +showMenu(): void
    +viewResearchCabinet(): void
    +addResearchPaper(ResearchPaper): void
    +createResearchProject(ResearchProject): void
    +notifyNewPaper(String, ResearchPaper): void
}

class GraduateStudent {
    -supervisorUsername: String
    +showMenu(): void
    +setSupervisor(Researcher): void
    +addResearchPaper(ResearchPaper): void
    +createResearchProject(ResearchProject): void
    +notifyNewPaper(String, ResearchPaper): void
}

class ResearcherDecorator {
    -user: User
    -papers: List<ResearchPaper>
    -projects: List<ResearchProject>
    +ResearcherDecorator(user: User)
    +addResearchPaper(ResearchPaper): void
    +createResearchProject(ResearchProject): void
    +calculateHIndex(): int
}

' ==========================================
' RELATIONSHIPS
' ==========================================

' Inheritance
User <|-- Student
User <|-- Employee
Employee <|-- Teacher
Teacher <|-- Dean
Employee <|-- Admin
Employee <|-- Manager
Employee <|-- TechSupport
Employee <|-- Librarian
Employee <|-- EmployeeResearcher
Student <|-- GraduateStudent

' Interfaces
Researcher <|.. Teacher
Researcher <|.. EmployeeResearcher
Researcher <|.. GraduateStudent
Researcher <|.. ResearcherDecorator

Subscriber <|.. Teacher
Subscriber <|.. Librarian
Subscriber <|.. GraduateStudent
Subscriber <|.. EmployeeResearcher

CanBorrowBook <|.. Teacher
CanBorrowBook <|.. Student

Managable <|.. Manager

' Dependencies (Admin creates)
Admin ..> Student : creates
Admin ..> Teacher : creates
Admin ..> Manager : creates
Admin ..> Dean : creates
Admin ..> Librarian : creates
Admin ..> TechSupport : creates
Admin ..> EmployeeResearcher : creates

' Associations
Database --> User : stores
Database --> Course : stores
Database --> Message : stores
Database --> Request : stores
Database --> Organization : stores
Database --> News : stores

Student "1" *-- "0..*" Course : enrolledCourses
Course "1" *-- "0..*" Student : students
Course "1" *-- "0..*" Teacher : teachers
Course "1" *-- "0..*" Lesson : lessons
Course "1" *-- "0..*" AttestationResult : grades

Teacher "1" *-- "0..*" Course : taughtCourses
Teacher "1" *-- "0..*" Book : borrowedBooks
Student "1" *-- "0..*" Book : borrowedBooks

Student "1" *-- "0..*" Organization : organizations
Organization "1" *-- "1..*" Student : members

ResearchProject "1" *-- "0..*" ResearchPaper : publishedPapers
ResearchProject "1" --> "0..*" Subscriber : subscribers

User --> Language
User --> Faculty
User --> Gender
Manager --> ManagerPosition
Teacher --> TeacherPosition

@enduml
