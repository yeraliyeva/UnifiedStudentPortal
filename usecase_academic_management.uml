@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #343A40
}

' ==========================================
' ACTORS
' ==========================================
actor "🎓 Student" as Student
actor "👨‍🏫 Teacher" as Teacher
actor "📊 Manager" as Manager
actor "🛡️ Admin" as Admin

actor "👨‍💼 Dean" as Dean
actor "⚙️ Automated System" as System

' ==========================================
' SYSTEM BOUNDARY
' ==========================================
rectangle "University Management System Boundary" {

    package "Global / Base Functions" {
        usecase "Log In" as UC_Login
        usecase "View / Edit Personal Info" as UC_Profile
        usecase "Change Language" as UC_Lang
        usecase "Send Message / View Inbox" as UC_Msg
        usecase "View / Comment on News" as UC_News
        usecase "Submit Request" as UC_SubmitReq
        usecase "View My Requests" as UC_ViewMyReq
    }

    package "Academic Operations" {
        usecase "View Enrolled Courses" as UC_ViewEnrolled
        usecase "Enroll in Course" as UC_Enroll
        usecase "Drop Course" as UC_Drop
        usecase "View Transcript & GPA" as UC_Transcript
        usecase "View Teacher Info & Rate" as UC_RateTch
        usecase "Create / Join / View Organizations" as UC_Orgs
        
        usecase "View Taught Courses" as UC_ViewTaught
        usecase "Put Marks / Attestations" as UC_PutMarks
        usecase "View Student Attestations" as UC_ViewAttest
        usecase "View Office Hours Schedule" as UC_OfficeHours
        usecase "Send Formal Complaint" as UC_Complaint
    }

    package "Management & Administration" {
        usecase "View All Users" as UC_ViewAllUsers
        usecase "Create Users / Roles" as UC_CreateUser
        usecase "Remove User" as UC_DeleteUser
        usecase "View Global Logs / User Logs" as UC_Logs
        
        usecase "View Filtered Requests" as UC_ViewReq
        usecase "Process / Approve Request" as UC_ProcessReq
        usecase "Create Course" as UC_CreateCourse
        usecase "Assign Teacher to Course" as UC_AssignCourse
        usecase "Add Lesson to Course" as UC_AddLesson
        usecase "Add / Edit / Delete News" as UC_ManageNews
        usecase "View Statistics & Students by GPA" as UC_Stats
    }

    package "Automated System Triggers" {
        usecase "Auto-Calculate GPA" as SYS_CalcGPA
        usecase "Enforce Academic Limits" as SYS_CheckLimits
        usecase "Route Status Update Messages" as SYS_MsgRouting
    }
}

' ==========================================
' COUPLING & INCLUDES (Internal Logic)
' ==========================================
UC_Enroll .> SYS_CheckLimits : <<includes>>
UC_Transcript .> SYS_CalcGPA : <<includes>>
UC_ProcessReq .> SYS_MsgRouting : <<includes>>
SYS_MsgRouting .> UC_Msg : <<includes>>

' ==========================================
' ACTOR CONNECTIONS
' ==========================================
Student --> UC_Login
Student --> UC_Profile
Student --> UC_Lang
Student --> UC_Msg
Student --> UC_News
Student --> UC_SubmitReq
Student --> UC_ViewMyReq

Teacher --> UC_Login
Teacher --> UC_Profile
Teacher --> UC_Lang
Teacher --> UC_Msg
Teacher --> UC_News
Teacher --> UC_SubmitReq
Teacher --> UC_ViewMyReq

Admin --> UC_Login
Admin --> UC_Profile
Admin --> UC_Lang
Admin --> UC_Msg
Admin --> UC_News
Admin --> UC_SubmitReq
Admin --> UC_ViewMyReq

Manager --> UC_Login
Manager --> UC_Profile
Manager --> UC_Lang
Manager --> UC_Msg
Manager --> UC_News
Manager --> UC_SubmitReq
Manager --> UC_ViewMyReq

Student --> UC_ViewEnrolled
Student --> UC_Enroll
Student --> UC_Drop
Student --> UC_Transcript
Student --> UC_RateTch
Student --> UC_Orgs

Teacher --> UC_ViewTaught
Teacher --> UC_PutMarks
Teacher --> UC_ViewAttest
Teacher --> UC_OfficeHours
Teacher --> UC_Complaint

Admin --> UC_ViewAllUsers
Admin --> UC_CreateUser
Admin --> UC_DeleteUser
Admin --> UC_Logs
Admin --> UC_ManageNews

Manager --> UC_ViewReq
Manager --> UC_ProcessReq
Manager --> UC_CreateCourse
Manager --> UC_AssignCourse
Manager --> UC_AddLesson
Manager --> UC_ManageNews
Manager --> UC_Stats

UC_Complaint --> Dean : Routed to
UC_SubmitReq --> Dean : Processed by
Dean --> UC_ViewReq
Dean --> UC_ProcessReq

System --> SYS_CalcGPA
System --> SYS_CheckLimits
System --> SYS_MsgRouting

@enduml
