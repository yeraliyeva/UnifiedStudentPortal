classDiagram
    direction TB

    %% ══════════════════════════════════════════════════════════════
    %%  LAYER 1 · PRESENTATION — CLI  (src/presentation)
    %% ══════════════════════════════════════════════════════════════

    namespace Presentation {
        class Console {
            <<interface>>
            +println(line String)
            +print(text String)
            +readLine(prompt String) String
            +readInt(prompt String) int
        }
        class StdConsole {
            +println(line String)
            +print(text String)
            +readLine(prompt String) String
            +readInt(prompt String) int
        }
        class LoginScreen {
            -users UserRepository
            -hasher PasswordHasher
            -console Console
            +run() Optional~User~
        }
        class Menu {
            <<interface>>
            +run()
        }
        class MenuItem {
            +label String
            +action Runnable
        }
        class MenuFactory {
            <<interface>>
            +menuFor(user User) Menu
        }
        class BecomeResearcherAction {
            -ctx AppContext
            +run(rc ResearcherCapable)
        }
        class ResearcherMenuExtension {
            -ctx AppContext
            +items(rc ResearcherCapable) List~MenuItem~
        }
        class AdminMenu {
            -ctx AppContext
            +run()
        }
        class StudentMenu {
            -ctx AppContext
            +run()
        }
        class GraduateStudentMenu {
            -ctx AppContext
            +run()
        }
        class TeacherMenu {
            -ctx AppContext
            +run()
        }
        class DeanMenu {
            -ctx AppContext
            +run()
        }
        class ManagerMenu {
            -ctx AppContext
            +run()
        }
        class LibrarianMenu {
            -ctx AppContext
            +run()
        }
        class TechSupportMenu {
            -ctx AppContext
            +run()
        }
        class EmployeeResearcherMenu {
            -ctx AppContext
            +run()
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  BOOTSTRAP  (src/bootstrap)
    %% ══════════════════════════════════════════════════════════════

    namespace Bootstrap {
        class AppContext {
            +console Console
            +loginScreen LoginScreen
            +menuFactory MenuFactory
            +users UserRepository
            +courses CourseRepository
            +books BookRepository
            +messages MessageRepository
            +news NewsRepository
            +requests RequestRepository
            +orders OrderRepository
            +papers ResearchPaperRepository
            +projects ResearchProjectRepository
            +organizations OrganizationRepository
            +notifications NotificationRepository
            +logs LogRepository
            +enrollmentService EnrollmentService
            +paperPublisher PaperPublisher
            +gpaCalculator GpaCalculator
            +hIndexCalculator HIndexCalculator
            +citationFormatter CitationFormatter
            +roomScheduler RoomScheduler
            +subscriptionService SubscriptionService
            +withJsonStorage(dataDir Path)$ AppContext
        }
        class DataSeeder {
            -ctx AppContext
            +seedIfEmpty()
        }
        class DefaultMenuFactory {
            -ctx AppContext
            +menuFor(user User) Menu
        }
        class IdSequenceWarmup {
            +warm(ctx AppContext)$
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  LAYER 2 · APPLICATION — USE CASES  (src/application)
    %% ══════════════════════════════════════════════════════════════

    namespace ApplicationAdmin {
        class CreateStudent {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, degree DegreeType, year int) Result~Student~
        }
        class CreateTeacher {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String, deg String, pos TeacherPosition) Result~Teacher~
        }
        class CreateGradStudent {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, degree DegreeType, year int) Result~GraduateStudent~
        }
        class CreateDean {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String, deg String) Result~Dean~
        }
        class CreateManager {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String, pos ManagerPosition) Result~Manager~
        }
        class CreateLibrarian {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String) Result~Librarian~
        }
        class CreateTechSupport {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String) Result~TechSupport~
        }
        class CreateEmpResearcher {
            -users UserRepository
            -log LogRepository
            +execute(username Username, hash String, name PersonName, gender Gender, dob LocalDate, email Email, faculty Faculty, salary Money, hireDate LocalDate, ins String, field String) Result~EmployeeResearcher~
        }
        class DeleteUser {
            -users UserRepository
            -log LogRepository
            +execute(actor Username, target Username) Result~Void~
        }
        class GenerateAcademicReport {
            -users UserRepository
            -courses CourseRepository
            -gpa GpaCalculator
            +execute() String
        }
        class GenerateTopResearcherNews {
            -users UserRepository
            -papers ResearchPaperRepository
            -news NewsRepository
            -hIndex HIndexCalculator
            +execute()
        }
    }

    namespace ApplicationCourse {
        class EnrollInCourse {
            -users UserRepository
            -courses CourseRepository
            -enrollment EnrollmentService
            -log LogRepository
            +execute(student Username, course CourseId) Result~Void~
        }
        class DropCourse {
            -users UserRepository
            -courses CourseRepository
            -log LogRepository
            +execute(student Username, course CourseId) Result~Void~
        }
        class RecordMarks {
            -users UserRepository
            -courses CourseRepository
            -log LogRepository
            +execute(teacher Username, course CourseId, student Username, att1 int, att2 int, exam int) Result~Void~
        }
        class AssignTeacher {
            -users UserRepository
            -courses CourseRepository
            -log LogRepository
            +execute(teacher Username, course CourseId) Result~Void~
        }
        class CreateCourse {
            -courses CourseRepository
            -sequence IdSequence
            -log LogRepository
            +execute(name String, credits int, type DisciplineType, capacity int) Result~Course~
        }
        class SetCourseCapacity {
            -courses CourseRepository
            +execute(course CourseId, max int) Result~Void~
        }
        class SetCoursePrerequisite {
            -courses CourseRepository
            +execute(course CourseId, prereq CourseId) Result~Void~
        }
        class AddLesson {
            -courses CourseRepository
            -scheduler RoomScheduler
            +execute(course CourseId, type LessonType, day WeekDay, time String, room String) Result~Void~
        }
        class ViewTranscript {
            -users UserRepository
            -courses CourseRepository
            -gpa GpaCalculator
            +execute(student Username) String
        }
    }

    namespace ApplicationLibrary {
        class BorrowBook {
            -books BookRepository
            -users UserRepository
            -log LogRepository
            +execute(borrower Username, title String) Result~Void~
        }
        class ReturnBook {
            -books BookRepository
            -log LogRepository
            +execute(borrower Username, book BookId) Result~Void~
        }
        class AddBook {
            -books BookRepository
            -sequence IdSequence
            +execute(title String, author String) Result~Book~
        }
        class RemoveBook {
            -books BookRepository
            +execute(book BookId) Result~Void~
        }
    }

    namespace ApplicationMessaging {
        class SendMessage {
            -messages MessageRepository
            -users UserRepository
            -sequence IdSequence
            +execute(from Username, to Username, subject String, body String, urgency UrgencyLevel) Result~Void~
        }
        class PublishNews {
            -news NewsRepository
            -sequence IdSequence
            -log LogRepository
            +execute(author Username, title String, body String) Result~Void~
        }
        class CommentOnNews {
            -news NewsRepository
            +execute(newsId int, comment String) Result~Void~
        }
        class SubmitRequest {
            -requests RequestRepository
            -sequence IdSequence
            +execute(requester Username, type HelpType, faculty Faculty, urgency UrgencyLevel, info String) Result~Void~
        }
        class ProcessRequest {
            -requests RequestRepository
            -users UserRepository
            +execute(requestId int, status RequestStatus) Result~Void~
        }
        class CreateITOrder {
            -orders OrderRepository
            -sequence IdSequence
            +execute(requester Username, description String) Result~Void~
        }
        class AcceptOrder {
            -orders OrderRepository
            -log LogRepository
            +execute(executor Username, orderId int) Result~Void~
        }
        class CompleteOrder {
            -orders OrderRepository
            -log LogRepository
            +execute(executor Username, orderId int) Result~Void~
        }
    }

    namespace ApplicationOrganization {
        class CreateOrganization {
            -organizations OrganizationRepository
            -users UserRepository
            -log LogRepository
            +execute(head Username, name String) Result~Organization~
        }
        class JoinOrganization {
            -organizations OrganizationRepository
            -log LogRepository
            +execute(member Username, orgName String) Result~Void~
        }
    }

    namespace ApplicationResearch {
        class CreateResearchProject {
            -projects ResearchProjectRepository
            -users UserRepository
            -sequence IdSequence
            -log LogRepository
            +execute(supervisor Username, journal String, topic String) Result~ResearchProject~
        }
        class JoinResearchProject {
            -projects ResearchProjectRepository
            -users UserRepository
            +execute(participant Username, journal String) Result~Void~
        }
        class PublishPaper {
            -publisher PaperPublisher
            -users UserRepository
            -sequence IdSequence
            +execute(author Username, title String, journal String, pages int, doi String) Result~ResearchPaper~
        }
        class SubscribeToJournal {
            -subscription SubscriptionService
            -users UserRepository
            +execute(researcher Username, journal String) Result~Void~
        }
        class UnsubscribeFromJournal {
            -subscription SubscriptionService
            -users UserRepository
            +execute(researcher Username, journal String) Result~Void~
        }
        class GenerateCitation {
            -papers ResearchPaperRepository
            -formatter CitationFormatter
            +execute(paperId PaperId, format PaperFormat) Result~String~
        }
        class SetSupervisor {
            -users UserRepository
            -projects ResearchProjectRepository
            -hIndex HIndexCalculator
            -papers ResearchPaperRepository
            +execute(supervisor Username, gradStudent Username) Result~Void~
        }
    }

    namespace ApplicationUser {
        class BecomeResearcher {
            -users UserRepository
            -log LogRepository
            +execute(user Username, field String) Result~Void~
        }
        class RateTeacher {
            -users UserRepository
            -log LogRepository
            +execute(student Username, teacher Username, rating int) Result~Void~
        }
        class ComplainAboutStudent {
            -users UserRepository
            -messages MessageRepository
            -sequence IdSequence
            +execute(teacher Username, student Username, reason String) Result~Void~
        }
        class Result~T~ {
            -value T
            -error String
            -success boolean
            +ok(value T)$ Result~T~
            +fail(error String)$ Result~T~
            +isOk() boolean
            +value() T
            +error() String
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  LAYER 3 · DOMAIN — CAPABILITIES & USERS  (src/domain/user)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainCapabilities {
        class ResearcherCapable {
            <<interface>>
            +isResearcher() boolean
            +activateResearcher(field String)
            +researcherProfile() ResearcherProfile
        }
        class BookBorrowerCapable {
            <<interface>>
        }
        class PasswordHasher {
            <<interface>>
            +hash(plain String) String
            +matches(plain String, hash String) boolean
        }
    }

    namespace DomainUsers {
        class User {
            <<abstract>>
            -username Username
            -passwordHash String
            -name PersonName
            -gender Gender
            -dateOfBirth LocalDate
            -email Email
            -faculty Faculty
            -language Language
            +username() Username
            +passwordHash() String
            +name() PersonName
            +gender() Gender
            +dateOfBirth() LocalDate
            +email() Email
            +faculty() Faculty
            +language() Language
            +changePassword(newHash String)
            +changeEmail(newEmail Email)
            +changeLanguage(lang Language)
            +matchesPassword(hash String) boolean
            +equals(o Object) boolean
            +hashCode() int
            +toString() String
        }
        class Employee {
            <<abstract>>
            -salary Money
            -hireDate LocalDate
            -insuranceNumber String
            +salary() Money
            +hireDate() LocalDate
            +insuranceNumber() String
        }
        class Admin {
        }
        class Student {
            -degreeType DegreeType
            -studyYear int
            -availableCredits Credits
            -failCount int
            -enrolled Set~CourseId~
            -completed Set~CourseId~
            -researcherProfile ResearcherProfile
            +MAX_FAILS$ int
            +degreeType() DegreeType
            +studyYear() int
            +availableCredits() Credits
            +failCount() int
            +hasReachedFailLimit() boolean
            +enrolledCourses() Set~CourseId~
            +completedCourses() Set~CourseId~
            +recordEnrollment(id CourseId, cost Credits)
            +recordDrop(id CourseId, refund Credits)
            +recordCompletion(id CourseId)
            +recordFail()
            +rehydrate(credits int, fails int, enrolled Iterable~CourseId~, completed Iterable~CourseId~)
            +isResearcher() boolean
            +activateResearcher(field String)
            +researcherProfile() ResearcherProfile
        }
        class GraduateStudent {
            -supervisorUsername Username
            +supervisor() Optional~Username~
            +setSupervisor(s Username)
        }
        class Teacher {
            -degree String
            -position TeacherPosition
            -taughtCourses Set~CourseId~
            -ratings List~Integer~
            -researcherProfile ResearcherProfile
            +degree() String
            +position() TeacherPosition
            +setPosition(p TeacherPosition)
            +taughtCourses() Set~CourseId~
            +recordCourseAssignment(id CourseId)
            +addRating(r int)
            +ratings() List~Integer~
            +averageRating() double
            +rehydrate(courses Iterable~CourseId~, ratings Iterable~Integer~)
            +isResearcher() boolean
            +activateResearcher(field String)
            +researcherProfile() ResearcherProfile
        }
        class Dean {
        }
        class Manager {
            -position ManagerPosition
            +position() ManagerPosition
        }
        class Librarian {
        }
        class TechSupport {
        }
        class EmployeeResearcher {
            -defaultField String
            -researcherProfile ResearcherProfile
            +defaultField() String
            +isResearcher() boolean
            +activateResearcher(field String)
            +researcherProfile() ResearcherProfile
        }
        class ResearcherProfile {
            -owner Username
            -field String
            -subscribedJournals Set~String~
            +owner() Username
            +field() String
            +subscribe(journal String)
            +unsubscribe(journal String)
            +subscribedJournals() Set~String~
            +isSubscribedTo(journal String) boolean
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — COURSE AGGREGATE  (src/domain/course)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainCourse {
        class Course {
            -id CourseId
            -name String
            -credits Credits
            -type DisciplineType
            -capacity Capacity
            -teacherUsernames Set~Username~
            -studentUsernames Set~Username~
            -lessons List~Lesson~
            -prerequisites Set~CourseId~
            -grades Map~Username, Grade~
            +id() CourseId
            +name() String
            +credits() Credits
            +type() DisciplineType
            +capacity() Capacity
            +rename(newName String)
            +changeCapacity(c Capacity)
            +enroll(student Username)
            +unenroll(student Username)
            +hasStudent(student Username) boolean
            +students() Set~Username~
            +isFull() boolean
            +remainingSeats() int
            +assignTeacher(teacher Username)
            +teachers() Set~Username~
            +addLesson(l Lesson)
            +lessons() List~Lesson~
            +addPrerequisite(p CourseId)
            +prerequisites() Set~CourseId~
            +recordGrade(student Username, grade Grade)
            +gradeOf(student Username) Optional~Grade~
            +allGrades() Map~Username, Grade~
            +equals(o Object) boolean
            +hashCode() int
            +toString() String
        }
        class CourseId {
            <<record>>
            +value String
            +of(n int)$ CourseId
            +toString() String
        }
        class Capacity {
            <<record>>
            +max int
            +UNLIMITED$ Capacity
            +canFit(currentEnrolled int) boolean
            +remaining(currentEnrolled int) int
        }
        class Lesson {
            <<record>>
            +type LessonType
            +slot TimeSlot
            +room Room
            +isExam() boolean
            +toString() String
        }
        class TimeSlot {
            <<record>>
            +day WeekDay
            +time String
            +overlaps(other TimeSlot) boolean
            +toString() String
        }
        class Room {
            <<record>>
            +name String
            +sameAs(other Room) boolean
            +toString() String
        }
        class Grade {
            <<record>>
            +firstHalf int
            +secondHalf int
            +exam int
            +PASSING_TOTAL$ int
            +total() int
            +isPassing() boolean
            +letter() String
            +toString() String
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — RESEARCH AGGREGATE  (src/domain/research)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainResearch {
        class ResearchPaper {
            -id PaperId
            -title String
            -author Username
            -journal JournalName
            -abstractText String
            -pages int
            -doi String
            -publishedDate LocalDate
            -citations int
            +id() PaperId
            +title() String
            +author() Username
            +journal() JournalName
            +abstractText() String
            +pages() int
            +doi() String
            +publishedDate() LocalDate
            +citations() int
            +cite()
            +length() int
            +toString() String
        }
        class ResearchProject {
            -id int
            -journal JournalName
            -topic String
            -supervisor Username
            -participants Set~Username~
            -publishedPapers List~PaperId~
            +id() int
            +journal() JournalName
            +topic() String
            +supervisor() Username
            +participants() Set~Username~
            +publishedPapers() List~PaperId~
            +addParticipant(u Username)
            +recordPublication(id PaperId)
            +toString() String
        }
        class PaperId {
            <<record>>
            +value int
            +toString() String
        }
        class JournalName {
            <<record>>
            +value String
            +matches(other String) boolean
            +toString() String
        }
        class HIndex {
            <<record>>
            +value int
            +MIN_FOR_SUPERVISION$ HIndex
            +atLeast(other HIndex) boolean
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — LIBRARY  (src/domain/library)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainLibrary {
        class Book {
            -id BookId
            -title String
            -author String
            -borrowedBy Username
            +id() BookId
            +title() String
            +author() String
            +isBorrowed() boolean
            +borrower() Optional~Username~
            +lendTo(user Username)
            +returnFrom(user Username)
            +toString() String
        }
        class BookId {
            <<record>>
            +value int
            +toString() String
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — MESSAGING  (src/domain/messaging)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainMessaging {
        class Message {
            -id int
            -sender Username
            -recipient Username
            -subject String
            -body String
            -urgency UrgencyLevel
            -sentAt LocalDateTime
            -status MessageStatus
            +id() int
            +sender() Username
            +recipient() Username
            +subject() String
            +body() String
            +urgency() UrgencyLevel
            +sentAt() LocalDateTime
            +status() MessageStatus
            +markRead()
            +compareTo(o Message) int
            +toString() String
        }
        class News {
            -id int
            -title String
            -body String
            -author Username
            -publishedAt LocalDateTime
            -comments List~String~
            -pinned boolean
            +id() int
            +title() String
            +body() String
            +author() Username
            +publishedAt() LocalDateTime
            +comments() List~String~
            +isPinned() boolean
            +edit(title String, body String)
            +addComment(comment String)
            +compareTo(o News) int
            +toString() String
        }
        class Request {
            -id int
            -requester Username
            -type HelpType
            -faculty Faculty
            -urgency UrgencyLevel
            -additionalInfo String
            -status RequestStatus
            +id() int
            +requester() Username
            +type() HelpType
            +faculty() Faculty
            +urgency() UrgencyLevel
            +additionalInfo() String
            +status() RequestStatus
            +changeStatus(s RequestStatus)
            +toString() String
        }
        class Order {
            -id int
            -requester Username
            -description String
            -createdAt LocalDate
            -status OrderStatus
            -executor Username
            +id() int
            +requester() Username
            +description() String
            +createdAt() LocalDate
            +status() OrderStatus
            +executor() Optional~Username~
            +accept(executor Username)
            +reject()
            +complete()
            +toString() String
        }
        class Notification {
            <<record>>
            +recipient Username
            +text String
            +at LocalDateTime
            +of(recipient Username, text String)$ Notification
            +toString() String
        }
    }

    namespace DomainOrganization {
        class Organization {
            -name String
            -head Username
            -members Set~Username~
            +name() String
            +head() Username
            +members() Set~Username~
            +isMember(u Username) boolean
            +addMember(u Username)
            +toString() String
        }
    }

    namespace DomainLogging {
        class LogEntry {
            <<record>>
            +at LocalDateTime
            +actor Username
            +action String
            +now(actor Username, action String)$ LogEntry
            +toString() String
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — ENROLLMENT RULES  (src/domain/rules)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainRules {
        class EnrollmentRule {
            <<interface>>
            +check(student Student, course Course) EnrollmentDecision
        }
        class EnrollmentDecision {
            <<record>>
            +allowed boolean
            +reason String
            +allow()$ EnrollmentDecision
            +deny(reason String)$ EnrollmentDecision
        }
        class MaxFailLimitRule {
            +check(student Student, course Course) EnrollmentDecision
        }
        class AlreadyEnrolledRule {
            +check(student Student, course Course) EnrollmentDecision
        }
        class CreditLimitRule {
            +check(student Student, course Course) EnrollmentDecision
        }
        class CapacityRule {
            +check(student Student, course Course) EnrollmentDecision
        }
        class PrerequisiteRule {
            -courses CourseRepository
            +PrerequisiteRule(courses CourseRepository)
            +check(student Student, course Course) EnrollmentDecision
        }
        class ScheduleConflictRule {
            -courses CourseRepository
            +ScheduleConflictRule(courses CourseRepository)
            +check(student Student, course Course) EnrollmentDecision
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — SERVICES  (src/domain/service)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainServices {
        class EnrollmentService {
            -rules List~EnrollmentRule~
            +EnrollmentService(rules List~EnrollmentRule~)
            +tryEnroll(student Student, course Course) EnrollmentDecision
        }
        class RoomScheduler {
            -courses CourseRepository
            +RoomScheduler(courses CourseRepository)
            +isAvailable(room Room, slot TimeSlot) boolean
        }
        class GpaCalculator {
            -courses CourseRepository
            +GpaCalculator(courses CourseRepository)
            +of(student Student) double
        }
        class HIndexCalculator {
            +calculate(papers List~ResearchPaper~) HIndex
        }
        class CitationFormatter {
            +format(paper ResearchPaper, format PaperFormat) String
        }
        class PaperPublisher {
            -papers ResearchPaperRepository
            -projects ResearchProjectRepository
            -notifications NotificationRepository
            -news NewsRepository
            -users UserRepository
            +publish(paper ResearchPaper)
        }
        class SubscriptionService {
            -projects ResearchProjectRepository
            +subscribe(researcher ResearcherCapable, journal String) boolean
            +unsubscribe(researcher ResearcherCapable, journal String)
        }
    }

    %% ══════════════════════════════════════════════════════════════
    %%  DOMAIN — SHARED VALUE OBJECTS  (src/domain/shared)
    %% ══════════════════════════════════════════════════════════════

    namespace DomainShared {
        class Username {
            -value String
            +Username(value String)
            +value() String
            +equals(o Object) boolean
            +hashCode() int
            +toString() String
        }
        class PersonName {
            <<record>>
            +first String
            +last String
            +full() String
        }
        class Email {
            <<record>>
            +address String
            +toString() String
        }
        class Money {
            <<record>>
            +amount double
            +toString() String
        }
        class Credits {
            <<record>>
            +value int
            +SEMESTER_LIMIT$ Credits
            +covers(required Credits) boolean
            +minus(other Credits) Credits
            +plus(other Credits) Credits
            +toString() String
        }
        class IdSequence {
            -counter AtomicInteger
            +next() int
            +peek() int
            +seedAtLeast(n int)
        }
    }

