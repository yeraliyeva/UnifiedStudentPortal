@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
    BackgroundColor #F8F9FA
    BorderColor #343A40
}

' ==========================================
' ACTORS
' ==========================================
actor "🎓 Student" as Student
actor "🎓 Grad Student" as Grad
actor "👨‍🏫 Teacher" as Teacher
actor "🔬 Employee Res." as EmpRes
actor "🛡️ Admin" as Admin

actor "🛠️ Tech Support" as TechSupport
actor "📚 Librarian" as Librarian
actor "⚙️ Automated System" as System

' ==========================================
' SYSTEM BOUNDARY
' ==========================================
rectangle "Research, Library & Support Subsystem" {

    package "Global / Base Functions" {
        usecase "Log In" as UC_Login
        usecase "View / Edit Personal Info" as UC_Profile
        usecase "Change Language" as UC_Lang
        usecase "Send Message / View Inbox" as UC_Msg
        usecase "View / Comment on News" as UC_News
        usecase "Submit Request" as UC_SubmitReq
        usecase "View My Requests" as UC_ViewMyReq
    }

    package "Research Publications" {
        usecase "View Research Cabinet" as UC_ViewRes
        usecase "Publish Research Paper" as UC_Publish
        usecase "Create Research Project" as UC_CreateProj
        usecase "Print Papers Sorted" as UC_PrintPapers
        usecase "Set PhD/Master Supervisor" as UC_SetSup
    }

    package "Library System" {
        usecase "View All Books" as UC_ViewBooks
        usecase "Add / Remove Books" as UC_ManageBooks
        usecase "Borrow / Return Book" as UC_BorrowReturn
    }

    package "Technical Support Operations" {
        usecase "Create IT Support Ticket" as UC_OrderSupport
        usecase "View New / My Orders" as UC_ViewNewOrders
        usecase "Accept / Complete Order" as UC_ProcessOrder
        usecase "Run Fix System Diagnostics" as UC_FixSys
    }

    package "Automated System Triggers" {
        usecase "Auto-Calculate H-Index" as SYS_CalcHIndex
        usecase "Auto-Generate News on Publish" as SYS_NewsGen
        usecase "Notify Project Subscribers" as SYS_Notify
        usecase "Route Status Update Messages" as SYS_MsgRouting
        usecase "Generate Top Researcher News" as UC_TopRes
    }
}

' ==========================================
' COUPLING & INCLUDES (Internal Logic)
' ==========================================
UC_Publish .> SYS_CalcHIndex : <<includes>>
UC_Publish .> SYS_NewsGen : <<includes>>
UC_Publish .> SYS_Notify : <<includes>>
UC_ProcessOrder .> SYS_MsgRouting : <<includes>>
SYS_MsgRouting .> UC_Msg : <<includes>>

' ==========================================
' ACTOR CONNECTIONS
' ==========================================
Student --> UC_Login
Student --> UC_Profile
Student --> UC_Lang
Student --> UC_Msg
Student --> UC_News
Student --> UC_SubmitReq
Student --> UC_ViewMyReq

Grad --> UC_Login
Grad --> UC_Profile
Grad --> UC_Lang
Grad --> UC_Msg
Grad --> UC_News
Grad --> UC_SubmitReq
Grad --> UC_ViewMyReq

Teacher --> UC_Login
Teacher --> UC_Profile
Teacher --> UC_Lang
Teacher --> UC_Msg
Teacher --> UC_News
Teacher --> UC_SubmitReq
Teacher --> UC_ViewMyReq

EmpRes --> UC_Login
EmpRes --> UC_Profile
EmpRes --> UC_Lang
EmpRes --> UC_Msg
EmpRes --> UC_News
EmpRes --> UC_SubmitReq
EmpRes --> UC_ViewMyReq

Admin --> UC_Login
Admin --> UC_Profile
Admin --> UC_Lang
Admin --> UC_Msg
Admin --> UC_News
Admin --> UC_SubmitReq
Admin --> UC_ViewMyReq

Student --> UC_ViewBooks
Student --> UC_BorrowReturn

Teacher --> UC_ViewBooks
Teacher --> UC_BorrowReturn

Grad --> UC_ViewRes
Grad --> UC_Publish
Grad --> UC_CreateProj
Grad --> UC_PrintPapers
Grad --> UC_SetSup

Teacher --> UC_ViewRes
Teacher --> UC_Publish
Teacher --> UC_CreateProj
Teacher --> UC_PrintPapers

EmpRes --> UC_ViewRes
EmpRes --> UC_Publish
EmpRes --> UC_CreateProj
EmpRes --> UC_PrintPapers

Teacher --> UC_OrderSupport
Admin --> UC_TopRes

UC_OrderSupport --> TechSupport : Routed to
TechSupport --> UC_ViewNewOrders
TechSupport --> UC_ProcessOrder
TechSupport --> UC_FixSys

Librarian --> UC_ViewBooks
Librarian --> UC_ManageBooks
SYS_Notify --> Librarian : Alerts

System --> SYS_CalcHIndex
System --> SYS_NewsGen
System --> SYS_Notify
System --> SYS_MsgRouting

@enduml
