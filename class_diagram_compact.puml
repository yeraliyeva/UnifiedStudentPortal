@startuml UniversitySystemCompact
' University Management System — Compact Architectural Class Diagram
' All classes present: essential ones shown fully, related ones merged into components
' Layers: Presentation → Bootstrap → Application → Domain → Infrastructure

top to bottom direction

skinparam monochrome false
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam nodesep 30
skinparam ranksep 45
skinparam packageStyle rectangle
skinparam defaultFontName "Arial"
skinparam defaultFontSize 10

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #8B949E
  FontColor #24292F
  HeaderBackgroundColor #F6F8FA
  AttributeFontColor #57606A
  StereotypeFontColor #0969DA
  ArrowColor #57606A
}
skinparam interface {
  BackgroundColor #DDF4FF
  BorderColor #0969DA
  FontColor #0550AE
  StereotypeFontColor #0969DA
}
skinparam abstract {
  BackgroundColor #FFF8C5
  BorderColor #9A6700
  FontColor #7D4E00
  StereotypeFontColor #9A6700
}
skinparam enum {
  BackgroundColor #DAFBE1
  BorderColor #1A7F37
  FontColor #116329
  StereotypeFontColor #1A7F37
}
skinparam package {
  BackgroundColor #F6F8FA
  BorderColor #D0D7DE
  FontStyle bold
  FontColor #24292F
}

' ════════════════════════════════════════════════════════════
'  LAYER 1 — PRESENTATION (CLI Interface)
' ════════════════════════════════════════════════════════════

package "1 · Presentation Layer" as PL #EBF5FF {

  interface Console {
    +println(line : String) : void
    +print(text : String) : void
    +readLine(prompt : String) : String
    +readInt(prompt : String) : int
  }

  class StdConsole implements Console

  class LoginScreen {
    -users : UserRepository
    -hasher : PasswordHasher
    -console : Console
    +run() : Optional<User>
  }

  interface Menu {
    +run() : void
  }

  interface MenuFactory {
    +menuFor(user : User) : Menu
  }

  class MenuItem {
    +label : String
    +action : Runnable
  }

  class AdminMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class StudentMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class GraduateStudentMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class TeacherMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class DeanMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class ManagerMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class LibrarianMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class TechSupportMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class EmployeeResearcherMenu implements Menu {
    -ctx : AppContext
    +run() : void
  }

  class BecomeResearcherAction {
    -ctx : AppContext
    +run(rc : ResearcherCapable) : void
  }

  class ResearcherMenuExtension {
    -ctx : AppContext
    +items(rc : ResearcherCapable) : List<MenuItem>
  }
}

' ════════════════════════════════════════════════════════════
'  LAYER 2 — BOOTSTRAP (Wiring / DI)
' ════════════════════════════════════════════════════════════

package "2 · Bootstrap" as BT #E6FFE6 {

  class AppContext {
    +console : Console
    +loginScreen : LoginScreen
    +menuFactory : MenuFactory
    +users : UserRepository
    +courses : CourseRepository
    +books : BookRepository
    +messages : MessageRepository
    +news : NewsRepository
    +requests : RequestRepository
    +orders : OrderRepository
    +papers : ResearchPaperRepository
    +projects : ResearchProjectRepository
    +organizations : OrganizationRepository
    +notifications : NotificationRepository
    +logs : LogRepository
    +enrollmentService : EnrollmentService
    +paperPublisher : PaperPublisher
    +gpaCalculator : GpaCalculator
    +hIndexCalculator : HIndexCalculator
    +citationFormatter : CitationFormatter
    +roomScheduler : RoomScheduler
    +subscriptionService : SubscriptionService
    +{static} withJsonStorage(dataDir : Path) : AppContext
  }

  class DefaultMenuFactory implements MenuFactory {
    -ctx : AppContext
    +menuFor(user : User) : Menu
  }

  class DataSeeder {
    -ctx : AppContext
    +seedIfEmpty() : void
  }

  class IdSequenceWarmup {
    +{static} warm(ctx : AppContext) : void
  }
}

' ════════════════════════════════════════════════════════════
'  LAYER 3 — APPLICATION (Use Cases — grouped into facades)
' ════════════════════════════════════════════════════════════

package "3 · Application Layer" as AP #FFFDE6 {

  class "Result<T>" as Result {
    -value : T
    -error : String
    -success : boolean
    +{static} ok(value : T) : Result<T>
    +{static} fail(error : String) : Result<T>
    +isOk() : boolean
    +value() : T
    +error() : String
  }

  class AdminUseCases <<11 classes>> {
    .. CreateStudent, CreateTeacher ..
    .. CreateGradStudent, CreateDean ..
    .. CreateManager, CreateLibrarian ..
    .. CreateTechSupport, CreateEmpResearcher ..
    .. DeleteUser ..
    .. GenerateAcademicReport ..
    .. GenerateTopResearcherNews ..
    ==
    +createStudent(Username, ...) : Result<Student>
    +createTeacher(Username, ...) : Result<Teacher>
    +createGradStudent(Username, ...) : Result<GraduateStudent>
    +createDean(Username, ...) : Result<Dean>
    +createManager(Username, ...) : Result<Manager>
    +createLibrarian(Username, ...) : Result<Librarian>
    +createTechSupport(Username, ...) : Result<TechSupport>
    +createEmpResearcher(Username, ...) : Result<EmployeeResearcher>
    +deleteUser(actor : Username, target : Username) : Result<Void>
    +generateAcademicReport() : String
    +generateTopResearcherNews() : void
  }

  class CourseUseCases <<9 classes>> {
    .. EnrollInCourse, DropCourse ..
    .. RecordMarks, AssignTeacher ..
    .. CreateCourse, SetCourseCapacity ..
    .. SetCoursePrerequisite ..
    .. AddLesson, ViewTranscript ..
    ==
    +enrollInCourse(student : Username, course : CourseId) : Result<Void>
    +dropCourse(student : Username, course : CourseId) : Result<Void>
    +recordMarks(teacher : Username, course : CourseId, student : Username, att1 : int, att2 : int, exam : int) : Result<Void>
    +assignTeacher(teacher : Username, course : CourseId) : Result<Void>
    +createCourse(name : String, credits : int, type : DisciplineType, cap : int) : Result<Course>
    +setCourseCapacity(course : CourseId, max : int) : Result<Void>
    +setCoursePrerequisite(course : CourseId, prereq : CourseId) : Result<Void>
    +addLesson(course : CourseId, type : LessonType, day : WeekDay, time : String, room : String) : Result<Void>
    +viewTranscript(student : Username) : String
  }

  class LibraryUseCases <<4 classes>> {
    .. BorrowBook, ReturnBook ..
    .. AddBook, RemoveBook ..
    ==
    +borrowBook(borrower : Username, title : String) : Result<Void>
    +returnBook(borrower : Username, book : BookId) : Result<Void>
    +addBook(title : String, author : String) : Result<Book>
    +removeBook(book : BookId) : Result<Void>
  }

  class MessagingUseCases <<8 classes>> {
    .. SendMessage, PublishNews ..
    .. CommentOnNews, SubmitRequest ..
    .. ProcessRequest, CreateITOrder ..
    .. AcceptOrder, CompleteOrder ..
    ==
    +sendMessage(from : Username, to : Username, subject : String, body : String, urgency : UrgencyLevel) : Result<Void>
    +publishNews(author : Username, title : String, body : String) : Result<Void>
    +commentOnNews(newsId : int, comment : String) : Result<Void>
    +submitRequest(requester : Username, type : HelpType, faculty : Faculty, urgency : UrgencyLevel, info : String) : Result<Void>
    +processRequest(id : int, status : RequestStatus) : Result<Void>
    +createITOrder(requester : Username, description : String) : Result<Void>
    +acceptOrder(executor : Username, orderId : int) : Result<Void>
    +completeOrder(executor : Username, orderId : int) : Result<Void>
  }

  class ResearchUseCases <<7 classes>> {
    .. CreateResearchProject ..
    .. JoinResearchProject ..
    .. PublishPaper, SubscribeToJournal ..
    .. UnsubscribeFromJournal ..
    .. GenerateCitation, SetSupervisor ..
    ==
    +createResearchProject(supervisor : Username, journal : String, topic : String) : Result<ResearchProject>
    +joinResearchProject(participant : Username, journal : String) : Result<Void>
    +publishPaper(author : Username, title : String, journal : String, pages : int, doi : String) : Result<ResearchPaper>
    +subscribeToJournal(researcher : Username, journal : String) : Result<Void>
    +unsubscribeFromJournal(researcher : Username, journal : String) : Result<Void>
    +generateCitation(paperId : PaperId, format : PaperFormat) : Result<String>
    +setSupervisor(supervisor : Username, gradStudent : Username) : Result<Void>
  }

  class UserUseCases <<3 classes>> {
    .. BecomeResearcher ..
    .. RateTeacher ..
    .. ComplainAboutStudent ..
    ==
    +becomeResearcher(user : Username, field : String) : Result<Void>
    +rateTeacher(student : Username, teacher : Username, rating : int) : Result<Void>
    +complainAboutStudent(teacher : Username, student : Username, reason : String) : Result<Void>
  }
}

' ════════════════════════════════════════════════════════════
'  LAYER 4 — DOMAIN (Business Logic)
' ════════════════════════════════════════════════════════════

package "4 · Domain Layer" as DM #FFF5EB {

  ' ── Merged: User Hierarchy ─────────────────────
  '    User, Admin, Student, GraduateStudent,
  '    Employee, Teacher, Dean, Manager,
  '    Librarian, TechSupport, EmployeeResearcher,
  '    ResearcherProfile
  class "User Hierarchy" as UserHierarchy <<12 classes>> {
    .. «abstract» User ..
    -username : Username
    -passwordHash : String
    -name : PersonName
    -gender : Gender {MALE, FEMALE}
    -dateOfBirth : LocalDate
    -email : Email
    -faculty : Faculty {SITE, SEOGI, SG, KMA, ISE, BS}
    -language : Language {ENGLISH, KAZAKH, RUSSIAN}
    +changePassword(hash) / changeEmail(email)
    +changeLanguage(lang) / matchesPassword(hash)
    .. «concrete» Admin ..
    .. «abstract» Employee ..
    -salary : Money
    -hireDate : LocalDate
    -insuranceNumber : String
    .. «concrete» Student (implements ResearcherCapable, BookBorrowerCapable) ..
    -degreeType : DegreeType {BACHELOR, MASTER, DOCTORATE}
    -studyYear : int
    -availableCredits : Credits
    -failCount : int
    -enrolled : Set<CourseId>
    -completed : Set<CourseId>
    +{static} MAX_FAILS : int
    +recordEnrollment(id, cost) / recordDrop(id, refund)
    +recordCompletion(id) / recordFail()
    +hasReachedFailLimit() : boolean
    +isResearcher() / activateResearcher(field)
    .. «concrete» GraduateStudent extends Student ..
    -supervisorUsername : Username
    +supervisor() : Optional<Username>
    +setSupervisor(s : Username)
    .. «concrete» Teacher (implements ResearcherCapable, BookBorrowerCapable) ..
    -degree : String
    -position : TeacherPosition {LECTOR, SENIOR_LECTOR, PROFESSOR}
    -taughtCourses : Set<CourseId>
    -ratings : List<Integer>
    +recordCourseAssignment(id) / addRating(r)
    +averageRating() : double
    +isResearcher() / activateResearcher(field)
    .. «concrete» Dean extends Teacher ..
    .. «concrete» Manager ..
    -position : ManagerPosition {OR, DEPARTMENT, DEANS_OFFICE}
    .. «concrete» Librarian ..
    .. «concrete» TechSupport ..
    .. «concrete» EmployeeResearcher (implements ResearcherCapable) ..
    -defaultField : String
    +isResearcher() / activateResearcher(field)
    ==
    .. «value» ResearcherProfile ..
    -owner : Username
    -field : String
    -subscribedJournals : Set<String>
    +subscribe(journal) / unsubscribe(journal)
    +isSubscribedTo(journal) : boolean
  }

  ' ── Capability Interfaces ──────────────────────
  interface ResearcherCapable {
    +isResearcher() : boolean
    +activateResearcher(field : String) : void
    +researcherProfile() : ResearcherProfile
  }

  interface BookBorrowerCapable

  interface PasswordHasher {
    +hash(plain : String) : String
    +matches(plain : String, hash : String) : boolean
  }

  ' ── Merged: Course Aggregate ───────────────────
  '    Course, CourseId, Capacity, Lesson,
  '    TimeSlot, Room, Grade
  class "Course Aggregate" as CourseAggregate <<7 classes>> {
    .. «entity» Course ..
    -id : CourseId {value : String, of(int)}
    -name : String
    -credits : Credits {value : int, SEMESTER_LIMIT, covers(), minus(), plus()}
    -type : DisciplineType {MAJOR, MINOR, FREE}
    -capacity : Capacity {max : int, UNLIMITED, canFit(int), remaining(int)}
    -teacherUsernames : Set<Username>
    -studentUsernames : Set<Username>
    -lessons : List<Lesson>
    -prerequisites : Set<CourseId>
    -grades : Map<Username, Grade>
    +enroll(student) / unenroll(student)
    +hasStudent(student) / isFull() / remainingSeats()
    +assignTeacher(teacher) / teachers()
    +addLesson(l) / lessons()
    +addPrerequisite(p) / prerequisites()
    +recordGrade(student, grade) / gradeOf(student) / allGrades()
    ==
    .. «record» Grade ..
    +firstHalf : int / secondHalf : int / exam : int
    +{static} PASSING_TOTAL : int
    +total() / isPassing() / letter()
    .. «record» Lesson ..
    +type : LessonType {LECTURE, PRACTICE, OFFICE_HOURS, EXAM}
    +slot : TimeSlot {day : WeekDay, time : String, overlaps(other)}
    +room : Room {name : String}
    +isExam() : boolean
    .. «enum» WeekDay {MON..SUN} ..
  }

  ' ── Merged: Research Aggregate ─────────────────
  '    ResearchPaper, ResearchProject, PaperId,
  '    JournalName, HIndex
  class "Research Aggregate" as ResearchAggregate <<5 classes>> {
    .. «entity» ResearchPaper ..
    -id : PaperId {value : int}
    -title : String
    -author : Username
    -journal : JournalName {value : String, matches(other)}
    -abstractText : String
    -pages : int
    -doi : String
    -publishedDate : LocalDate
    -citations : int
    +cite() / length()
    ==
    .. «entity» ResearchProject ..
    -id : int
    -journal : JournalName
    -topic : String
    -supervisor : Username
    -participants : Set<Username>
    -publishedPapers : List<PaperId>
    +addParticipant(u) / recordPublication(id)
    ==
    .. «record» HIndex ..
    +value : int
    +{static} MIN_FOR_SUPERVISION : HIndex
    +atLeast(other) : boolean
    .. «enum» PaperFormat {PLAIN_TEXT, BIBTEX} ..
  }

  ' ── Merged: Messaging Entities ─────────────────
  '    Message, News, Request, Order,
  '    Notification, LogEntry
  class "Messaging & Support Entities" as MsgEntities <<6 classes>> {
    .. «entity» Message (implements Comparable) ..
    -id : int / -sender : Username / -recipient : Username
    -subject : String / -body : String
    -urgency : UrgencyLevel {LOW, MEDIUM, HIGH}
    -sentAt : LocalDateTime
    -status : MessageStatus {UNREAD, READ}
    +markRead() / compareTo(o)
    ==
    .. «entity» News (implements Comparable) ..
    -id : int / -title : String / -body : String
    -author : Username / -publishedAt : LocalDateTime
    -comments : List<String> / -pinned : boolean
    +edit(title, body) / addComment(comment)
    ==
    .. «entity» Request ..
    -id : int / -requester : Username
    -type : HelpType {TRANSCRIPT_FOR_SEMESTER, ..., REQUEST_FOR_CREATING_ORGANIZATION}
    -faculty : Faculty / -urgency : UrgencyLevel
    -status : RequestStatus {PENDING, ACCEPTED, NOT_APPROVED, APPROVED, REJECTED}
    +changeStatus(s)
    ==
    .. «entity» Order ..
    -id : int / -requester : Username
    -description : String / -createdAt : LocalDate
    -status : OrderStatus {NEW, ACCEPTED, REJECTED, DONE}
    -executor : Username
    +accept(executor) / reject() / complete()
    ==
    .. «record» Notification ..
    +recipient : Username / +text : String / +at : LocalDateTime
    +{static} of(recipient, text) : Notification
    .. «record» LogEntry ..
    +at : LocalDateTime / +actor : Username / +action : String
    +{static} now(actor, action) : LogEntry
  }

  ' ── Merged: Library & Organization ─────────────
  class "Library & Organization" as LibOrgEntities <<3 classes>> {
    .. «entity» Book ..
    -id : BookId {value : int}
    -title : String / -author : String
    -borrowedBy : Username
    +isBorrowed() / borrower() : Optional<Username>
    +lendTo(user) / returnFrom(user)
    ==
    .. «entity» Organization ..
    -name : String / -head : Username
    -members : Set<Username>
    +isMember(u) / addMember(u)
  }

  ' ── Shared Value Objects ───────────────────────
  class "Shared Value Objects" as SharedVO <<6 classes>> {
    .. Username ..
    +value : String
    .. «record» PersonName ..
    +first : String / +last : String / +full() : String
    .. «record» Email ..
    +address : String
    .. «record» Money ..
    +amount : double
    .. «record» Credits ..
    +value : int / +{static} SEMESTER_LIMIT : Credits
    +covers(required) / minus(other) / plus(other)
    .. IdSequence ..
    -counter : AtomicInteger
    +next() : int / +peek() : int / +seedAtLeast(n)
  }

  ' ── Domain Services (all shown fully) ──────────

  class EnrollmentService {
    -rules : List<EnrollmentRule>
    +tryEnroll(student : Student, course : Course) : EnrollmentDecision
  }

  interface EnrollmentRule {
    +check(student : Student, course : Course) : EnrollmentDecision
  }

  class "EnrollmentDecision" as ED <<record>> {
    +allowed : boolean
    +reason : String
    +{static} allow() : EnrollmentDecision
    +{static} deny(reason : String) : EnrollmentDecision
  }

  class "Enrollment Rules" as EnrollRules <<6 classes>> {
    .. all implement EnrollmentRule ..
    MaxFailLimitRule
    AlreadyEnrolledRule
    CreditLimitRule
    CapacityRule
    PrerequisiteRule {-courses : CourseRepository}
    ScheduleConflictRule {-courses : CourseRepository}
  }

  class PaperPublisher {
    -papers : ResearchPaperRepository
    -projects : ResearchProjectRepository
    -notifications : NotificationRepository
    -news : NewsRepository
    -users : UserRepository
    +publish(paper : ResearchPaper) : void
  }

  class GpaCalculator {
    -courses : CourseRepository
    +of(student : Student) : double
  }

  class HIndexCalculator {
    +calculate(papers : List<ResearchPaper>) : HIndex
  }

  class CitationFormatter {
    +format(paper : ResearchPaper, format : PaperFormat) : String
  }

  class RoomScheduler {
    -courses : CourseRepository
    +isAvailable(room : Room, slot : TimeSlot) : boolean
  }

  class SubscriptionService {
    -projects : ResearchProjectRepository
    +subscribe(researcher : ResearcherCapable, journal : String) : boolean
    +unsubscribe(researcher : ResearcherCapable, journal : String) : void
  }

  ' ── Repository Ports (all shown fully) ─────────

  interface UserRepository {
    +save(user : User) : void
    +findByUsername(username : Username) : Optional<User>
    +exists(username : Username) : boolean
    +delete(username : Username) : void
    +findAll() : Collection<User>
  }

  interface CourseRepository {
    +save(course : Course) : void
    +findById(id : CourseId) : Optional<Course>
    +findAll() : Collection<Course>
  }

  interface BookRepository {
    +save(book : Book) : void
    +findById(id : BookId) : Optional<Book>
    +findFirstAvailableByTitle(title : String) : Optional<Book>
    +findAll() : Collection<Book>
    +delete(id : BookId) : void
  }

  interface MessageRepository {
    +save(message : Message) : void
    +inboxOf(recipient : Username) : List<Message>
  }

  interface NewsRepository {
    +save(news : News) : void
    +findById(id : int) : Optional<News>
    +findAllSorted() : List<News>
    +delete(id : int) : void
  }

  interface RequestRepository {
    +save(request : Request) : void
    +findById(id : int) : Optional<Request>
    +findAll() : List<Request>
    +findByRequester(requester : Username) : List<Request>
  }

  interface OrderRepository {
    +save(order : Order) : void
    +findById(id : int) : Optional<Order>
    +findAll() : List<Order>
  }

  interface ResearchPaperRepository {
    +save(paper : ResearchPaper) : void
    +findById(id : PaperId) : Optional<ResearchPaper>
    +findByAuthor(author : Username) : List<ResearchPaper>
    +findAll() : Collection<ResearchPaper>
  }

  interface ResearchProjectRepository {
    +save(project : ResearchProject) : void
    +findByJournal(journal : JournalName) : Optional<ResearchProject>
    +findAll() : Collection<ResearchProject>
  }

  interface OrganizationRepository {
    +save(org : Organization) : void
    +findByName(name : String) : Optional<Organization>
    +findAll() : Collection<Organization>
  }

  interface NotificationRepository {
    +save(notification : Notification) : void
    +findFor(recipient : Username) : List<Notification>
    +clearFor(recipient : Username) : void
  }

  interface LogRepository {
    +append(entry : LogEntry) : void
    +findAll() : List<LogEntry>
    +findByActor(actor : Username) : List<LogEntry>
  }
}

' ════════════════════════════════════════════════════════════
'  LAYER 5 — INFRASTRUCTURE (Persistence)
' ════════════════════════════════════════════════════════════

package "5 · Infrastructure Layer" as IF #FFF0F0 {

  class PlainPasswordHasher implements PasswordHasher {
    +hash(plain : String) : String
    +matches(plain : String, hash : String) : boolean
  }

  ' ── Merged: Persistence Engine ─────────────────
  class "Persistence Engine" as PersistenceEngine <<8 classes>> {
    .. «interface» Database ..
    +readTable(name : String) : List<JsonValue>
    +writeTable(name : String, rows : List<JsonValue>)
    .. «concrete» JsonFileDatabase implements Database ..
    -root : Path
    ==
    .. «interface» EntityMapper<T, ID> ..
    +toJson(entity : T) : JsonValue
    +fromJson(json : JsonValue) : T
    +idOf(entity : T) : ID / +idAsString(id : ID) : String
    .. «concrete» MapperHelpers ..
    +{static} strOrNull / intVal / doubleVal / boolVal
    ==
    .. «generic» Repository<T, ID> ..
    -db : Database / -tableName : String / -mapper : EntityMapper
    +save(entity) / +find(id) / +findAll() / +delete(entity)
    +count() / +select() : QueryBuilder / +where(field, op, value)
    .. «generic» QueryBuilder<T, ID> ..
    -conditions : List<Condition>
    +where / whereEq / whereContains / whereMatch
    +orderBy / limit / offset
    +list() / first() / count() / deleteAll() / updateEach()
    ==
    .. «enum» Op {EQ, NEQ, GT, LT, GTE, LTE, CONTAINS, STARTS_WITH, ENDS_WITH, IN} ..
  }

  ' ── Merged: ORM Repository Implementations ────
  class "ORM Repositories" as OrmRepos <<12 classes>> {
    .. all implement domain repository ports ..
    .. all delegate to Repository<T, ID> ..
    OrmUserRepository         : Repository<User, Username>
    OrmCourseRepository       : Repository<Course, CourseId>
    OrmBookRepository         : Repository<Book, BookId>
    OrmMessageRepository      : Repository<Message, Integer>
    OrmNewsRepository         : Repository<News, Integer>
    OrmRequestRepository      : Repository<Request, Integer>
    OrmOrderRepository        : Repository<Order, Integer>
    OrmResearchPaperRepository : Repository<ResearchPaper, PaperId>
    OrmResearchProjectRepository : Repository<ResearchProject, Integer>
    OrmOrganizationRepository : Repository<Organization, String>
    OrmNotificationRepository : Repository<Notification, String>
    OrmLogRepository          : Repository<LogEntry, String>
  }

  ' ── Merged: Entity Mappers ────────────────────
  class "Entity Mappers" as Mappers <<12 classes>> {
    .. all implement EntityMapper<T, ID> ..
    UserMapper / CourseMapper / BookMapper
    MessageMapper / NewsMapper / RequestMapper
    OrderMapper / ResearchPaperMapper
    ResearchProjectMapper / OrganizationMapper
    NotificationMapper / LogEntryMapper
  }

  ' ── Merged: InMemory test doubles ─────────────
  class "InMemory Repositories" as InMemRepos <<11 classes>> {
    .. all implement domain repository ports ..
    .. used for testing ..
    InMemoryUserRepository : Map<Username, User>
    InMemoryCourseRepository : Map<CourseId, Course>
    InMemoryBookRepository : Map<BookId, Book>
    InMemoryMessageRepository : List<Message>
    InMemoryNewsRepository : Map<Integer, News>
    InMemoryOrderRepository : Map<Integer, Order>
    InMemoryResearchPaperRepository : Map<PaperId, ResearchPaper>
    InMemoryResearchProjectRepository : Map<Integer, ResearchProject>
    InMemoryOrganizationRepository : Map<String, Organization>
    InMemoryNotificationRepository : List<Notification>
    InMemoryLogRepository : List<LogEntry>
  }

  ' ── Merged: i18n + Logging ────────────────────
  class "i18n & Logging" as I18nLog <<4 classes>> {
    .. «interface» Translator ..
    +get(key : String) : String
    +fmt(key : String, args : Object[]) : String
    .. «concrete» PropertiesTranslator ..
    -bundle : ResourceBundle
    +setLanguage(lang : Language)
    ==
    .. «interface» Logger ..
    +log(actor : Username, action : String) : void
    .. «concrete» RepositoryLogger ..
    -repository : LogRepository
  }
}

