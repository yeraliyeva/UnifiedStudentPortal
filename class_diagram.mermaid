    %% ══════════════════════════════════════════════════════════════
    %%  LAYER 4 · INFRASTRUCTURE  (src/infrastructure)
    %% ══════════════════════════════════════════════════════════════

    namespace InfraAuth {
        class PlainPasswordHasher {
            +hash(plain String) String
            +matches(plain String, hash String) boolean
        }
    }

    namespace InfraI18n {
        class Translator {
            <<interface>>
            +get(key String) String
            +fmt(key String, args Object[]) String
        }
        class PropertiesTranslator {
            -bundle ResourceBundle
            +get(key String) String
            +fmt(key String, args Object[]) String
            +setLanguage(lang Language)
        }
    }

    namespace InfraLogging {
        class Logger {
            <<interface>>
            +log(actor Username, action String)
        }
        class RepositoryLogger {
            -repository LogRepository
            +log(actor Username, action String)
        }
    }

    namespace InfraJson {
        class JsonValue {
            <<sealed>>
            +asString() String
            +asInt() int
            +asDouble() double
            +asBoolean() boolean
            +asArray() List~JsonValue~
            +asObject() Map~String, JsonValue~
            +isNull() boolean
        }
        class JsonString {
            +value String
        }
        class JsonNumber {
            +value double
        }
        class JsonBool {
            +value boolean
        }
        class JsonNull {
        }
        class JsonArray {
            +elements List~JsonValue~
        }
        class JsonObject {
            +fields Map~String, JsonValue~
            +get(key String) JsonValue
            +has(key String) boolean
        }
        class JsonReader {
            +parse(text String)$ JsonValue
        }
        class JsonWriter {
            +write(value JsonValue)$ String
        }
        class JsonObjectBuilder {
            -fields Map~String, JsonValue~
            +put(key String, value JsonValue) JsonObjectBuilder
            +put(key String, value String) JsonObjectBuilder
            +put(key String, value int) JsonObjectBuilder
            +put(key String, value double) JsonObjectBuilder
            +put(key String, value boolean) JsonObjectBuilder
            +build() JsonObject
        }
    }

    namespace InfraDatabase {
        class Database {
            <<interface>>
            +readTable(name String) List~JsonValue~
            +writeTable(name String, rows List~JsonValue~)
        }
        class JsonFileDatabase {
            -root Path
            +JsonFileDatabase(root Path)
            +readTable(name String) List~JsonValue~
            +writeTable(name String, rows List~JsonValue~)
        }
    }

    namespace InfraOrm {
        class EntityMapper~T,ID~ {
            <<interface>>
            +toJson(entity T) JsonValue
            +fromJson(json JsonValue) T
            +idOf(entity T) ID
            +idAsString(id ID) String
        }
        class Repository~T,ID~ {
            -db Database
            -tableName String
            -mapper EntityMapper~T,ID~
            +save(entity T) T
            +create(entity T) T
            +update(entity T) T
            +find(id ID) Optional~T~
            +findById(id ID) Optional~T~
            +findAll() List~T~
            +delete(entity T) boolean
            +deleteAll() int
            +count() int
            +select() QueryBuilder~T,ID~
            +where(field String, op Op, value Object) QueryBuilder~T,ID~
            +whereEq(field String, value Object) QueryBuilder~T,ID~
        }
        class QueryBuilder~T,ID~ {
            -conditions List~Condition~
            -typedPredicate Predicate~T~
            -ordering Comparator~T~
            -limit int
            -offset int
            +where(field String, op Op, value Object) QueryBuilder~T,ID~
            +whereEq(field String, value Object) QueryBuilder~T,ID~
            +whereContains(field String, value Object) QueryBuilder~T,ID~
            +whereMatch(predicate Predicate~T~) QueryBuilder~T,ID~
            +orderBy(comparator Comparator~T~) QueryBuilder~T,ID~
            +limit(n int) QueryBuilder~T,ID~
            +offset(n int) QueryBuilder~T,ID~
            +list() List~T~
            +first() Optional~T~
            +count() int
            +deleteAll() int
            +updateEach(consumer Consumer~T~) int
        }
        class Condition {
            +field String
            +op Op
            +value Object
            +matches(row JsonObject) boolean
        }
        class Op {
            <<enumeration>>
            EQ
            NEQ
            GT
            LT
            GTE
            LTE
            CONTAINS
            STARTS_WITH
            ENDS_WITH
            IN
        }
        class MapperHelpers {
            +strOrNull(obj JsonObject, key String)$ String
            +intVal(obj JsonObject, key String)$ int
            +doubleVal(obj JsonObject, key String)$ double
            +boolVal(obj JsonObject, key String)$ boolean
        }
    }

    namespace InfraMappers {
        class UserMapper {
            +toJson(user User) JsonValue
            +fromJson(json JsonValue) User
            +idOf(user User) Username
            +idAsString(id Username) String
        }
        class CourseMapper {
            +toJson(course Course) JsonValue
            +fromJson(json JsonValue) Course
            +idOf(course Course) CourseId
            +idAsString(id CourseId) String
        }
        class BookMapper {
            +toJson(book Book) JsonValue
            +fromJson(json JsonValue) Book
            +idOf(book Book) BookId
            +idAsString(id BookId) String
        }
        class MessageMapper {
            +toJson(msg Message) JsonValue
            +fromJson(json JsonValue) Message
            +idOf(msg Message) Integer
            +idAsString(id Integer) String
        }
        class NewsMapper {
            +toJson(news News) JsonValue
            +fromJson(json JsonValue) News
            +idOf(news News) Integer
            +idAsString(id Integer) String
        }
        class RequestMapper {
            +toJson(req Request) JsonValue
            +fromJson(json JsonValue) Request
            +idOf(req Request) Integer
            +idAsString(id Integer) String
        }
        class OrderMapper {
            +toJson(order Order) JsonValue
            +fromJson(json JsonValue) Order
            +idOf(order Order) Integer
            +idAsString(id Integer) String
        }
        class ResearchPaperMapper {
            +toJson(paper ResearchPaper) JsonValue
            +fromJson(json JsonValue) ResearchPaper
            +idOf(paper ResearchPaper) PaperId
            +idAsString(id PaperId) String
        }
        class ResearchProjectMapper {
            +toJson(project ResearchProject) JsonValue
            +fromJson(json JsonValue) ResearchProject
            +idOf(project ResearchProject) Integer
            +idAsString(id Integer) String
        }
        class OrganizationMapper {
            +toJson(org Organization) JsonValue
            +fromJson(json JsonValue) Organization
            +idOf(org Organization) String
            +idAsString(id String) String
        }
        class NotificationMapper {
            +toJson(n Notification) JsonValue
            +fromJson(json JsonValue) Notification
            +idOf(n Notification) String
            +idAsString(id String) String
        }
        class LogEntryMapper {
            +toJson(entry LogEntry) JsonValue
            +fromJson(json JsonValue) LogEntry
            +idOf(entry LogEntry) String
            +idAsString(id String) String
        }
    }

