        subgraph DOM_LIB["Library  (domain/library)"]
            direction LR
            Book["Book"]:::domain
            BookId["«record» BookId"]:::domain
        end

        subgraph DOM_MSG["Messaging  (domain/messaging)"]
            direction LR
            Message["Message"]:::domain
            News["News"]:::domain
            Request["Request"]:::domain
            Order["Order"]:::domain
            Notification["«record» Notification"]:::domain
        end

        subgraph DOM_ORG["Organization  (domain/organization)"]
            Organization["Organization"]:::domain
        end

        subgraph DOM_LOG["Logging  (domain/logging)"]
            LogEntry["«record» LogEntry"]:::domain
        end

        subgraph DOM_RULES["Enrollment Rules  (domain/rules)"]
            direction LR
            EnrollmentRule["«interface» EnrollmentRule"]:::iface
            EnrollmentDecision["«record» EnrollmentDecision"]:::rules
