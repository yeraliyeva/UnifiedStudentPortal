```mermaid
classDiagram
    direction LR

    %% =========================================================
    %% PALETTE — one color per package
    %% =========================================================
    classDef pkgUsers   fill:#FDEBD0,stroke:#D35400,stroke-width:1.5px,color:#000
    classDef pkgEdu     fill:#EAFAF1,stroke:#27AE60,stroke-width:1.5px,color:#000
    classDef pkgComm    fill:#E8F8F5,stroke:#1ABC9C,stroke-width:1.5px,color:#000
    classDef pkgData    fill:#FCF3CF,stroke:#B7950B,stroke-width:2px,color:#000
    classDef pkgIface   fill:#D6EAF8,stroke:#2980B9,stroke-width:1.5px,color:#000
    classDef pkgEnum    fill:#F4ECF7,stroke:#8E44AD,stroke-width:1.2px,color:#000
    classDef pkgCommon  fill:#FADBD8,stroke:#C0392B,stroke-width:1.5px,color:#000
    classDef pkgExc     fill:#FDEBD0,stroke:#7B241C,stroke-width:1.5px,color:#000

    %% =========================================================
    %% USERS
    %% =========================================================
    class User:::pkgUsers {
        <<abstract>>
        -username: String
        -password: String
        -firstName: String
        -lastName: String
        -faculty: Faculty
        -language: Language
        +showMenu()*
        +sendMessage(to, subj, body, urg)
        +viewInbox()
        +submitRequest(type, urg, info)
        +commentOnNews()
        +editPersonalInfo()
    }

    class Student:::pkgUsers {
        -enrolledCourses: List~Course~
        -completedCourses: List~Course~
        -borrowedBooks: List~Book~
        -notifications: List~String~
        -subscribedJournals: Set~String~
        -availableCredits: int
        -failCount: int
        +enrollCourse(c)
        +dropCourse(c)
        +calculateGPA() double
        +markCourseCompleted(c)
        +subscribeToJournal(j)
        +unsubscribeFromJournal(j)
        +rateTeacherInteractive()
    }

    class GraduateStudent:::pkgUsers {
        -supervisorUsername: String
        -myPapers: List~ResearchPaper~
        -diplomaPapers: List~ResearchPaper~
        -myProjects: List~ResearchProject~
        +setSupervisor(r)
        +addDiplomaPaper(p)
        +addResearchPaper(p)
        +createResearchProject(p)
        +calculateHIndex() int
    }

    class Employee:::pkgUsers {
        <<abstract>>
        -salary: double
        -hireDate: LocalDate
        -insuranceNumber: String
        +addOrder(desc)
    }

    class Teacher:::pkgUsers {
        -degree: String
        -position: TeacherPosition
        -taughtCourses: List~Course~
        -myPapers: List~ResearchPaper~
        -ratings: List~Integer~
        -subscribedJournals: Set~String~
        +assignToCourse(c)
        +putMarksInteractive()
        +sendComplaintAboutStudent()
        +addRating(r)
        +generateCitationInteractive()
        +subscribeJournalInteractive()
    }

    class Dean:::pkgUsers {
        +viewIncomingRequests()
        +approveRequest()
    }

    class EmployeeResearcher:::pkgUsers {
        -researchField: String
        -myPapers: List~ResearchPaper~
        -subscribedJournals: Set~String~
    }

    class Manager:::pkgUsers {
        -position: ManagerPosition
        +viewRequests()
        +processRequestInteractive()
        +createCourseInteractive()
        +assignTeacherToCourse()
        +addLessonToCourse()
        +isRoomAvailable(room, day, time) bool
        +setCoursePrerequisiteInteractive()
        +setCourseCapacityInteractive()
        +viewExamScheduleAll()
        +generateAcademicReport()
    }

    class Librarian:::pkgUsers {
        -subscribedJournals: Set~String~
        +viewAllBooks()
        +addBookInteractive()
        +removeBookInteractive()
        +subscribeJournalInteractive()
    }

    class TechSupport:::pkgUsers {
        +acceptOrder()
        +rejectOrder()
        +completeOrder()
        +runDiagnostics()
    }

    class Admin:::pkgUsers {
        +createStudent(...)
        +createTeacher(...)
        +createManager(...)
        +createDean(...)
        +viewAllUsers()
        +removeUser(name)
        +viewLogs()
        +generateTopResearcherNews()
    }

    class ResearcherDecorator:::pkgUsers {
        -wrappedUser: User
        -myPapers: List~ResearchPaper~
        +addResearchPaper(p)
        +calculateHIndex() int
    }

    %% =========================================================
    %% INTERFACES
    %% =========================================================
    class Researcher:::pkgIface {
        <<interface>>
        +addResearchPaper(p)
        +getMyPapers() List
        +calculateHIndex() int
        +createResearchProject(p)
        +getResearchProjects() List
        +printPapers(comparator)
    }

    class Subscriber:::pkgIface {
        <<interface>>
        +getUsername() String
        +notifyNewPaper(journal, paper)
    }

    class CanBorrowBook:::pkgIface {
        <<interface>>
        +borrowBook(b)
        +returnBook(b)
    }

    class Educationable:::pkgIface {
        <<interface>>
        +viewLessonSchedule()
        +viewExamsSchedule()
        +viewJournal()
        +viewDisciplineSchedule()
        +attendanceMark()
    }

    class Managable:::pkgIface {
        <<interface>>
        +viewAcademicStatistics()
    }

    %% =========================================================
    %% EDUCATION
    %% =========================================================
    class Course:::pkgEdu {
        -courseId: String
        -courseName: String
        -credits: int
        -type: DisciplineType
        -maxStudents: int
        -teachers: List~Teacher~
        -students: List~Student~
        -lessons: List~Lesson~
        -prerequisites: List~Course~
        -grades: Map~String, AttestationResult~
        +enrollStudent(s)
        +addLesson(l)
        +addPrerequisite(c)
        +setGrade(user, a1, a2, ex)
        +isFull() bool
        +getRemainingSeats() int
    }

    class Lesson:::pkgEdu {
        -type: LessonType
        -day: WeekDay
        -time: String
        -room: String
    }

    class AttestationResult:::pkgEdu {
        -firstHalf: int
        -secondHalf: int
        -exam: int
        +getTotal() int
        +getLetterGrade() String
        +isPassing() bool
    }

    class Book:::pkgEdu {
        -bookId: int
        -title: String
        -author: String
        -borrowed: bool
    }

    class Specialty:::pkgEdu {
        -faculty: Faculty
        -degree: DegreeType
        -courses: List~Course~
    }

    %% =========================================================
    %% COMMUNICATION
    %% =========================================================
    class Message:::pkgComm {
        -sender: String
        -recipient: String
        -subject: String
        -body: String
        -urgency: UrgencyLevel
        -status: MessageStatus
        +markRead()
    }

    class News:::pkgComm {
        -id: int
        -title: String
        -body: String
        -authorUsername: String
        -comments: List~String~
        +addComment(c)
        +edit(t, b)
    }

    class Request:::pkgComm {
        -id: int
        -requesterUsername: String
        -type: HelpType
        -status: RequestStatus
        -urgency: UrgencyLevel
    }

    class Order:::pkgComm {
        -id: int
        -description: String
        -status: OrderStatus
        -executor: String
        -requesterUsername: String
    }

    class Organization:::pkgComm {
        -name: String
        -headUsername: String
        -members: List~String~
        +addMember(name)
        +isMember(name) bool
    }

    class ResearchPaper:::pkgComm {
        -id: int
        -title: String
        -authorUsername: String
        -journalName: String
        -citations: int
        -pages: int
        -doi: String
        +incrementCitations()
        +getCitation(fmt) String
        +getLength() int
    }

    class ResearchProject:::pkgComm {
        -id: int
        -journalName: String
        -topic: String
        -supervisorUsername: String
        -participantUsernames: List~String~
        -publishedPapers: List~ResearchPaper~
        -subscribers: List~Subscriber~
        +publishPaper(p)
        +subscribe(s)
        +unsubscribe(s)
        +addParticipant(u)
    }

    %% =========================================================
    %% DATA / COMMON / EXCEPTIONS
    %% =========================================================
    class Database:::pkgData {
        <<singleton>>
        -instance: Database
        -users: Map
        -courses: List
        -books: List
        -messages: List
        -newsFeed: List
        -requests: List
        -orders: List
        -researchProjects: List
        -organizations: List
        +getInstance() Database
        +findCourseById(id) Optional
        +findProjectByJournal(j) Optional
        +generateTopResearcherNews()
        +getStudentsByGPA() List
        +getTopCitedResearcher() String
    }

    class LogManager:::pkgCommon {
        <<singleton>>
        -logs: List
        +log(user, action)
        +getLogsForUser(name) List
    }

    class Messages:::pkgCommon {
        <<utility>>
        -bundles: Map
        +get(key) String
        +fmt(key, args) String
        +setLanguage(lang)
    }

    class Login:::pkgCommon {
        +run() User
    }

    class PaperComparators:::pkgCommon {
        +BY_CITATIONS Comparator
        +BY_LENGTH Comparator
        +BY_DATE Comparator
        +BY_TITLE Comparator
    }

    class DataSeeder:::pkgCommon {
        +seed()
    }

    class LowHIndexException:::pkgExc {
        <<exception>>
    }
    class NotResearcherException:::pkgExc {
        <<exception>>
    }

    %% =========================================================
    %% INHERITANCE (extends)
    %% =========================================================
    User <|-- Student
    Student <|-- GraduateStudent
    User <|-- Employee
    Employee <|-- Teacher
    Teacher <|-- Dean
    Employee <|-- EmployeeResearcher
    Employee <|-- Manager
    Employee <|-- Librarian
    Employee <|-- TechSupport
    User <|-- Admin

    %% =========================================================
    %% INTERFACE IMPLEMENTATION (..|>)
    %% =========================================================
    Student          ..|> CanBorrowBook
    Student          ..|> Educationable
    Student          ..|> Subscriber
    GraduateStudent  ..|> Researcher
    Teacher          ..|> Researcher
    Teacher          ..|> CanBorrowBook
    Teacher          ..|> Subscriber
    EmployeeResearcher ..|> Researcher
    EmployeeResearcher ..|> Subscriber
    Manager          ..|> Managable
    Librarian        ..|> Subscriber
    ResearcherDecorator ..|> Researcher

    %% =========================================================
    %% COMPOSITION  *--   AGGREGATION  o--   ASSOCIATION  -->
    %% =========================================================
    Course "1" *-- "*" Lesson : has
    Course "1" *-- "*" AttestationResult : grades
    Course "*" o-- "*" Teacher : taught by
    Course "*" o-- "*" Student : enrolled
    Course "1" o-- "*" Course : prerequisites

    Student "1" o-- "*" Course : enrolled
    Student "1" o-- "*" Course : completed
    Student "1" o-- "*" Book : borrowed
    Teacher "1" o-- "*" Book : borrowed
    Teacher "1" o-- "*" Course : taught
    Teacher "1" o-- "*" ResearchPaper : authored
    GraduateStudent "1" o-- "*" ResearchPaper : authored
    EmployeeResearcher "1" o-- "*" ResearchPaper : authored

    ResearchProject "1" o-- "*" ResearchPaper : publishes
    ResearchProject "1" o-- "*" Subscriber : notifies

    ResearcherDecorator --> User : wraps

    %% Database holds collections of nearly everything
    Database o-- User
    Database o-- Course
    Database o-- Book
    Database o-- Message
    Database o-- News
    Database o-- Request
    Database o-- Order
    Database o-- ResearchProject
    Database o-- Organization
    Database o-- Specialty

    %% =========================================================
    %% USAGE / DEPENDENCY  ..>
    %% =========================================================
    Manager     ..> Course : manages
    Manager     ..> Request : processes
    Admin       ..> User : manages
    Teacher     ..> Dean : sends complaint
    Dean        ..> Request : approves
    TechSupport ..> Order : handles
    Student     ..> Teacher : rates
    Student     ..> Organization : creates / joins

    LogManager <.. Student : logs
    LogManager <.. Teacher : logs
    LogManager <.. Manager : logs
    LogManager <.. Admin   : logs

    Login ..> User : authenticates
    DataSeeder ..> Database : seeds
    Messages ..> User : i18n
```
