flowchart TD

    %% ── colour palette by layer ──────────────────────────────
    classDef cli    fill:#0d1b2a,stroke:#4cc9f0,color:#e0f7fa
    classDef boot   fill:#1a1a2e,stroke:#a78bfa,color:#ede9fe
    classDef app    fill:#12213d,stroke:#7b2d8b,color:#f3e8ff
    classDef domain fill:#0f3460,stroke:#e94560,color:#ffe4e6
    classDef iface  fill:#0f2027,stroke:#4cc9f0,color:#4cc9f0,stroke-dasharray:4 4
    classDef svc    fill:#1b3a4b,stroke:#06d6a0,color:#d0fef5
    classDef rules  fill:#2d1b69,stroke:#f77f00,color:#fff3cd
    classDef shared fill:#1a2c1e,stroke:#80ed99,color:#d8f3dc
    classDef enums  fill:#2c1810,stroke:#fb8500,color:#fff
    classDef repo   fill:#1a0533,stroke:#c77dff,color:#e9d5ff
    classDef infra  fill:#1c2833,stroke:#f4a261,color:#fdebd0
    classDef data   fill:#1b2a1b,stroke:#25a18e,color:#ccfbf1

    %% ════════════════════════════════════════════════════════
    %%   LAYER 1 · PRESENTATION / CLI
    %% ════════════════════════════════════════════════════════
    subgraph PRES["🖥️  PRESENTATION — CLI  (src/presentation)"]
        direction TB
        subgraph CLI_AUTH["auth"]
            LoginScreen["LoginScreen"]:::cli
        end
        subgraph CLI_CON["console"]
            Console["«interface» Console"]:::iface
            StdConsole["StdConsole"]:::cli
        end
        subgraph CLI_MENU["menus"]
            MenuIf["«interface» Menu"]:::iface
            MenuFactoryIf["«interface» MenuFactory"]:::iface
            MenuItem["MenuItem"]:::cli
            AdminMenu["AdminMenu"]:::cli
            StudentMenu["StudentMenu"]:::cli
            GradStudentMenu["GraduateStudentMenu"]:::cli
            TeacherMenu["TeacherMenu"]:::cli
            DeanMenu["DeanMenu"]:::cli
            ManagerMenu["ManagerMenu"]:::cli
            LibrarianMenu["LibrarianMenu"]:::cli
            TechSupportMenu["TechSupportMenu"]:::cli
            EmpResMenu["EmployeeResearcherMenu"]:::cli
            BecomeResAction["BecomeResearcherAction"]:::cli
            ResMenuExt["ResearcherMenuExtension"]:::cli
        end
    end

    %% ════════════════════════════════════════════════════════
    %%   BOOTSTRAP
    %% ════════════════════════════════════════════════════════
    subgraph BOOT["🔧  BOOTSTRAP  (src/bootstrap)"]
        direction LR
        AppContext["AppContext"]:::boot
        DataSeeder["DataSeeder"]:::boot
        DefaultMenuFactory["DefaultMenuFactory"]:::boot
        IdSequenceWarmup["IdSequenceWarmup"]:::boot
    end

    %% ════════════════════════════════════════════════════════
    %%   LAYER 2 · APPLICATION — USE CASES
    %% ════════════════════════════════════════════════════════
    subgraph APP["⚙️  APPLICATION — Use Cases  (src/application)"]
        direction TB
        ResultT["Result&lt;T&gt;"]:::app

        subgraph UC_ADM["admin"]
            direction LR
            CreateStudent["CreateStudent"]:::app
            CreateTeacher["CreateTeacher"]:::app
            CreateGradStudent["CreateGradStudent"]:::app
