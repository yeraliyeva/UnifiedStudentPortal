## 6. Presentation (CLI Menus) + Bootstrap

```mermaid
classDiagram
    direction LR

    classDef pkgCli   fill:#FDEBD0,stroke:#D35400,stroke-width:1.5px,color:#000
    classDef pkgMenu  fill:#FAE5D3,stroke:#A04000,stroke-width:1.5px,color:#000
    classDef pkgBoot  fill:#FCF3CF,stroke:#7D6608,stroke-width:2px,color:#000
    classDef pkgInfra fill:#D6EAF8,stroke:#1F618D,stroke-width:1.5px,color:#000

    %% ==== console abstraction ====
    class Console {
        <<interface>>
        +readLine(prompt) String
        +readInt(prompt) int
        +println(text)
    }
    class StdConsole
    Console <|.. StdConsole

    %% ==== infrastructure shared ====
    class Translator {
        <<interface>>
        +get(key) String
        +fmt(key, args) String
        +switchTo(lang)
    }
    class PropertiesTranslator
    Translator <|.. PropertiesTranslator

    class Logger {
        <<interface>>
        +log(actor, action)
    }
    class RepositoryLogger
    Logger <|.. RepositoryLogger

    class PasswordHasher {
        <<interface>>
        +hash(plain) String
        +matches(plain, hash) boolean
    }
    class PlainPasswordHasher
    PasswordHasher <|.. PlainPasswordHasher

    class AuthenticationService {
        -users: UserRepository
        -hasher: PasswordHasher
        +authenticate(name, pass) Optional~User~
    }

    %% ==== menu framework ====
    class MenuItem {
        +label: String
        +action: Runnable
    }
    class Menu {
        <<abstract>>
        #console: Console
        #title()*  String
        #items()*  List~MenuItem~
        +run()
    }
    Menu o-- "*" MenuItem

    class MenuFactory {
        <<interface>>
        +menuFor(user) Menu
    }
    class DefaultMenuFactory {
        -ctx: AppContext
        +menuFor(user) Menu
    }
    MenuFactory <|.. DefaultMenuFactory

    %% ==== role-specific menus ====
    class StudentMenu
    class GraduateStudentMenu
    class TeacherMenu
    class DeanMenu
    class ManagerMenu
    class AdminMenu
    class LibrarianMenu
    class TechSupportMenu
    class EmployeeResearcherMenu
    Menu <|-- StudentMenu
    Menu <|-- GraduateStudentMenu
    Menu <|-- TeacherMenu
    Menu <|-- DeanMenu
    Menu <|-- ManagerMenu
    Menu <|-- AdminMenu
    Menu <|-- LibrarianMenu
    Menu <|-- TechSupportMenu
    Menu <|-- EmployeeResearcherMenu

    %% ==== Become-Researcher gating ====
    class BecomeResearcherAction {
        -useCase: BecomeResearcher
        +run(user)
    }
    class ResearcherMenuExtension {
        +itemsFor(user) List~MenuItem~
    }
    StudentMenu --> BecomeResearcherAction
    StudentMenu --> ResearcherMenuExtension
    TeacherMenu --> BecomeResearcherAction
    TeacherMenu --> ResearcherMenuExtension
    GraduateStudentMenu --> BecomeResearcherAction
    GraduateStudentMenu --> ResearcherMenuExtension
    EmployeeResearcherMenu --> BecomeResearcherAction
    EmployeeResearcherMenu --> ResearcherMenuExtension
    DeanMenu --> BecomeResearcherAction
    DeanMenu --> ResearcherMenuExtension

    class LoginScreen {
        -auth: AuthenticationService
        +run() Optional~User~
    }

    %% ==== bootstrap / DI ====
    class AppContext {
        +database: Database
        +userRepository: UserRepository
        +courseRepository: CourseRepository
        +...all other repositories
        +enrollmentService: EnrollmentService
        +...all other domain services
        +enrollInCourse: EnrollInCourse
        +...all other use cases
        +menuFactory: MenuFactory
        +loginScreen: LoginScreen
        +withJsonStorage(path)$ AppContext
    }
    class DataSeeder {
        -ctx: AppContext
        +seedIfEmpty()
    }
    class IdSequenceWarmup {
        +warm(ctx)$
    }
    class Main {
        +main(args)$
    }

    AppContext o-- "many" UserRepository
    AppContext o-- "many" CourseRepository
    AppContext --> AuthenticationService
    AppContext --> Translator
    AppContext --> Logger
    AppContext --> Console
    AppContext --> MenuFactory
    AppContext --> LoginScreen

    DataSeeder --> AppContext
    IdSequenceWarmup --> AppContext
    Main --> AppContext : creates
    Main --> DataSeeder : seeds
    Main --> IdSequenceWarmup : warms
    Main --> LoginScreen : runs
    Main --> MenuFactory : routes by role

    %% ==== styles ====
    class Console:::pkgCli
    class StdConsole:::pkgCli
    class LoginScreen:::pkgCli

    class Menu:::pkgMenu
    class MenuItem:::pkgMenu
    class MenuFactory:::pkgMenu
    class DefaultMenuFactory:::pkgBoot
    class StudentMenu:::pkgMenu
    class GraduateStudentMenu:::pkgMenu
    class TeacherMenu:::pkgMenu
    class DeanMenu:::pkgMenu
    class ManagerMenu:::pkgMenu
    class AdminMenu:::pkgMenu
    class LibrarianMenu:::pkgMenu
    class TechSupportMenu:::pkgMenu
    class EmployeeResearcherMenu:::pkgMenu
    class BecomeResearcherAction:::pkgMenu
    class ResearcherMenuExtension:::pkgMenu

    class Translator:::pkgInfra
    class PropertiesTranslator:::pkgInfra
    class Logger:::pkgInfra
    class RepositoryLogger:::pkgInfra
    class PasswordHasher:::pkgInfra
    class PlainPasswordHasher:::pkgInfra
    class AuthenticationService:::pkgInfra

    class AppContext:::pkgBoot
    class DataSeeder:::pkgBoot
    class IdSequenceWarmup:::pkgBoot
    class Main:::pkgBoot
```
