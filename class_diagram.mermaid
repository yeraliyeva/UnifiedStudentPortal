    %% Repository ports → managed entities
    UserRepository ..> User : manages
    CourseRepository ..> Course : manages
    BookRepository ..> Book : manages
    MessageRepository ..> Message : manages
    NewsRepository ..> News : manages
    RequestRepository ..> Request : manages
    OrderRepository ..> Order : manages
    ResearchPaperRepository ..> ResearchPaper : manages
    ResearchProjectRepository ..> ResearchProject : manages
    OrganizationRepository ..> Organization : manages
    NotificationRepository ..> Notification : manages
    LogRepository ..> LogEntry : manages

    %% Infrastructure ORM delegates to Database + Mappers
    OrmUserRepository ..> Repository~T,ID~ : delegates
    OrmCourseRepository ..> Repository~T,ID~ : delegates
    OrmBookRepository ..> Repository~T,ID~ : delegates
    OrmMessageRepository ..> Repository~T,ID~ : delegates
    OrmNewsRepository ..> Repository~T,ID~ : delegates
    OrmRequestRepository ..> Repository~T,ID~ : delegates
    OrmOrderRepository ..> Repository~T,ID~ : delegates
    OrmResearchPaperRepository ..> Repository~T,ID~ : delegates
    OrmResearchProjectRepository ..> Repository~T,ID~ : delegates
    OrmOrganizationRepository ..> Repository~T,ID~ : delegates
    OrmNotificationRepository ..> Repository~T,ID~ : delegates
    OrmLogRepository ..> Repository~T,ID~ : delegates
    Repository~T,ID~ ..> Database : reads/writes
    Repository~T,ID~ ..> EntityMapper~T,ID~ : serializes via
    Repository~T,ID~ ..> QueryBuilder~T,ID~ : creates
    QueryBuilder~T,ID~ ..> Database : reads
    QueryBuilder~T,ID~ ..> EntityMapper~T,ID~ : materializes via
    QueryBuilder~T,ID~ "1" *-- "0..*" Condition : conditions
    Condition ..> Op : uses
    JsonFileDatabase ..> JsonReader : parses via
    JsonFileDatabase ..> JsonWriter : serializes via
    JsonReader ..> JsonValue : produces
    JsonWriter ..> JsonValue : consumes
    EntityMapper~T,ID~ ..|> UserMapper
    EntityMapper~T,ID~ ..|> CourseMapper
    EntityMapper~T,ID~ ..|> BookMapper
    EntityMapper~T,ID~ ..|> MessageMapper
    EntityMapper~T,ID~ ..|> NewsMapper
    EntityMapper~T,ID~ ..|> RequestMapper
    EntityMapper~T,ID~ ..|> OrderMapper
    EntityMapper~T,ID~ ..|> ResearchPaperMapper
    EntityMapper~T,ID~ ..|> ResearchProjectMapper
    EntityMapper~T,ID~ ..|> OrganizationMapper
    EntityMapper~T,ID~ ..|> NotificationMapper
    EntityMapper~T,ID~ ..|> LogEntryMapper
    JsonValue <|-- JsonString
    JsonValue <|-- JsonNumber
    JsonValue <|-- JsonBool
    JsonValue <|-- JsonNull
    JsonValue <|-- JsonArray
    JsonValue <|-- JsonObject
    RepositoryLogger ..> LogRepository : appends to
