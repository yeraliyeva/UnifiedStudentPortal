    %% ════════════════════════════════════════════════════════
    %%   LAYER 3 · DOMAIN MODEL
    %% ════════════════════════════════════════════════════════
    subgraph DOMAIN["🏛️  DOMAIN  (src/domain)"]
        direction TB

        subgraph DOM_CAP["Capability Interfaces"]
            direction LR
            ResearcherCapable["«interface» ResearcherCapable"]:::iface
            BookBorrowerCapable["«interface» BookBorrowerCapable"]:::iface
        end

        subgraph DOM_USR["Users  (domain/user)"]
            direction LR
            User["«abstract» User"]:::domain
            Employee["«abstract» Employee"]:::domain
            Admin["Admin"]:::domain
            Student["Student"]:::domain
            GraduateStudent["GraduateStudent"]:::domain
            Teacher["Teacher"]:::domain
            Dean["Dean"]:::domain
            Manager["Manager"]:::domain
            Librarian["Librarian"]:::domain
            TechSupport["TechSupport"]:::domain
            EmpResearcher["EmployeeResearcher"]:::domain
            ResearcherProfile["ResearcherProfile"]:::domain
        end

        subgraph DOM_CRS["Course Aggregate  (domain/course)"]
            direction LR
            Course["Course"]:::domain
            CourseId["«record» CourseId"]:::domain
            Capacity["«record» Capacity"]:::domain
            Lesson["«record» Lesson"]:::domain
            TimeSlot["«record» TimeSlot"]:::domain
            Room["«record» Room"]:::domain
            Grade["«record» Grade"]:::domain
        end

        subgraph DOM_RES["Research Aggregate  (domain/research)"]
            direction LR
            ResearchPaper["ResearchPaper"]:::domain
            ResearchProject["ResearchProject"]:::domain
            PaperId["«record» PaperId"]:::domain
            JournalName["«record» JournalName"]:::domain
            HIndex["«record» HIndex"]:::domain
