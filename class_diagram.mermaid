            HIndexCalculator["HIndexCalculator"]:::svc
            CitationFormatter["CitationFormatter"]:::svc
            PaperPublisher["PaperPublisher"]:::svc
            SubscriptionService["SubscriptionService"]:::svc
        end

        subgraph DOM_SHARED["Shared Value Objects  (domain/shared)"]
            direction LR
            Username["Username"]:::shared
            PersonName["«record» PersonName"]:::shared
            Email["«record» Email"]:::shared
            Money["«record» Money"]:::shared
            Credits["«record» Credits"]:::shared
            IdSequence["IdSequence"]:::shared
        end

        subgraph DOM_ENUM["Enumerations  (domain/enums)"]
            direction LR
            DegreeType["DegreeType"]:::enums
            Faculty["Faculty"]:::enums
            Gender["Gender"]:::enums
            Language["Language"]:::enums
            TeacherPosition["TeacherPosition"]:::enums
