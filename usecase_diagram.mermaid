```mermaid
flowchart LR
    %% ==========================================
    %% COLOR PALETTES & STYLING
    %% ==========================================
    classDef actorPrimary fill:#FDEBD0,stroke:#D35400,stroke-width:2px,color:#000
    classDef actorSecondary fill:#D6EAF8,stroke:#2980B9,stroke-width:2px,color:#000
    classDef systemActor fill:#E8DAEF,stroke:#8E44AD,stroke-width:2px,color:#000
    
    classDef ucBase fill:#F8F9FA,stroke:#343A40,stroke-width:1px,color:#000
    classDef ucCore fill:#EAFAF1,stroke:#27AE60,stroke-width:1px,color:#000
    classDef ucMgmt fill:#FDEDEC,stroke:#C0392B,stroke-width:1px,color:#000
    classDef ucRes fill:#E8F6F3,stroke:#1ABC9C,stroke-width:1px,color:#000
    classDef ucAuto fill:#F9EBEA,stroke:#A93226,stroke-width:1px,color:#000,stroke-dasharray: 5 5

    %% ==========================================
    %% LEFT SIDE: PRIMARY ACTORS (Producers / Initiators)
    %% ==========================================
    Student((🎓 Student)):::actorPrimary
    Grad((🎓 Grad Student)):::actorPrimary
    Teacher((👨‍🏫 Teacher)):::actorPrimary
    EmpRes((🔬 Employee Res.)):::actorPrimary
    Manager((📊 Manager)):::actorPrimary
    Admin((🛡️ Admin)):::actorPrimary

    %% ==========================================
    %% RIGHT SIDE: SECONDARY ACTORS (Consumers / Support)
    %% ==========================================
    Dean((👨‍💼 Dean)):::actorSecondary
    TechSupport((🛠️ Tech Support)):::actorSecondary
    Librarian((📚 Librarian)):::actorSecondary
    System[[⚙️ Automated System]]:::systemActor

    %% ==========================================
    %% CENTRAL SYSTEM BOUNDARY (The Rectangle)
    %% ==========================================
    subgraph UMS [University Management System Boundary]
        direction TB

        %% --- Shared / Reusable Modules ---
        subgraph Mod_Auth [Global / Base Functions]
            direction TB
            UC_Login([Log In]):::ucBase
            UC_Profile([View / Edit Personal Info]):::ucBase
            UC_Lang([Change Language]):::ucBase
            UC_Msg([Send Message / View Inbox]):::ucBase
            UC_News([View / Comment on News]):::ucBase
            UC_SubmitReq([Submit Request]):::ucBase
            UC_ViewMyReq([View My Requests]):::ucBase
        end

        %% --- Academic Module ---
        subgraph Mod_Acad [Academic Operations]
            direction TB
            UC_ViewEnrolled([View Enrolled Courses]):::ucCore
            UC_Enroll([Enroll in Course]):::ucCore
            UC_Drop([Drop Course]):::ucCore
            UC_Transcript([View Transcript & GPA]):::ucCore
            UC_RateTch([View Teacher Info & Rate]):::ucCore
            UC_Orgs([Create / Join / View Organizations]):::ucCore
            
            UC_ViewTaught([View Taught Courses]):::ucCore
            UC_PutMarks([Put Marks / Attestations]):::ucCore
            UC_ViewAttest([View Student Attestations]):::ucCore
            UC_OfficeHours([View Office Hours Schedule]):::ucCore
            UC_Complaint([Send Formal Complaint]):::ucCore
        end

        %% --- Management Module ---
        subgraph Mod_Mgmt [Management & Administration]
            direction TB
            UC_ViewAllUsers([View All Users]):::ucMgmt
            UC_CreateUser([Create Student / Teacher / Manager / etc.]):::ucMgmt
            UC_DeleteUser([Remove User]):::ucMgmt
            UC_Logs([View Global Logs / User Logs]):::ucMgmt
            UC_TopRes([Generate Top Researcher News]):::ucMgmt
            
            UC_ViewReq([View Filtered Requests]):::ucMgmt
            UC_ProcessReq([Process / Approve Request]):::ucMgmt
            UC_CreateCourse([Create Course]):::ucMgmt
            UC_AssignCourse([Assign Teacher to Course]):::ucMgmt
            UC_AddLesson([Add Lesson to Course]):::ucMgmt
            UC_ManageNews([Add / Edit / Delete News]):::ucMgmt
            UC_Stats([View Statistics & Students by GPA]):::ucMgmt
        end

        %% --- Research Module ---
        subgraph Mod_Res [Research Publications]
            direction TB
            UC_ViewRes([View Research Cabinet]):::ucRes
            UC_Publish([Publish Research Paper]):::ucRes
            UC_CreateProj([Create Research Project]):::ucRes
            UC_PrintPapers([Print Papers Sorted]):::ucRes
            UC_SetSup([Set PhD/Master Supervisor]):::ucRes
        end

        %% --- Library Module ---
        subgraph Mod_Lib [Library System]
            direction TB
            UC_ViewBooks([View All Books]):::ucRes
            UC_ManageBooks([Add / Remove Books]):::ucRes
            UC_BorrowReturn([Borrow / Return Book]):::ucRes
        end

        %% --- Tech Support Module ---
        subgraph Mod_Support [Technical Support Operations]
            direction TB
            UC_OrderSupport([Create IT Support Ticket]):::ucBase
            UC_ViewNewOrders([View New / My Orders]):::ucBase
            UC_ProcessOrder([Accept / Complete Order]):::ucBase
            UC_FixSys([Run Fix System Diagnostics]):::ucBase
        end

        %% --- Automated Background Jobs (Reusable Functions) ---
        subgraph Mod_Auto [Automated System Triggers]
            direction TB
            SYS_CalcGPA([Auto-Calculate GPA]):::ucAuto
            SYS_CalcHIndex([Auto-Calculate H-Index]):::ucAuto
            SYS_CheckLimits([Enforce Academic Limits]):::ucAuto
            SYS_NewsGen([Auto-Generate News on Publish]):::ucAuto
            SYS_Notify([Notify Project Subscribers]):::ucAuto
            SYS_MsgRouting([Route Status Update Messages]):::ucAuto
        end
    end

    %% ==========================================
    %% COUPLING & INCLUDES (Good Reusability)
    %% ==========================================
    
    %% Included dependencies inside the system
    UC_Enroll -.->|<<includes>>| SYS_CheckLimits
    UC_Transcript -.->|<<includes>>| SYS_CalcGPA
    UC_Publish -.->|<<includes>>| SYS_CalcHIndex
    UC_Publish -.->|<<includes>>| SYS_NewsGen
    UC_Publish -.->|<<includes>>| SYS_Notify
    UC_ProcessReq -.->|<<includes>>| SYS_MsgRouting
    UC_ProcessOrder -.->|<<includes>>| SYS_MsgRouting
    SYS_MsgRouting -.->|<<includes>>| UC_Msg

    %% ==========================================
    %% ACTOR CONNECTIONS (Left -> Middle -> Right)
    %% ==========================================

    %% Global connections
    Student & Teacher & Admin & Manager & EmpRes --> UC_Login & UC_Profile & UC_Lang & UC_Msg & UC_News & UC_SubmitReq & UC_ViewMyReq

    %% Student moves
    Student --> UC_ViewEnrolled & UC_Enroll & UC_Drop & UC_Transcript & UC_RateTch & UC_Orgs
    Student --> UC_ViewBooks & UC_BorrowReturn
    Grad --> UC_ViewRes & UC_Publish & UC_CreateProj & UC_PrintPapers & UC_SetSup

    %% Teacher & Researcher moves
    Teacher --> UC_ViewTaught & UC_PutMarks & UC_ViewAttest & UC_OfficeHours & UC_Complaint
    Teacher --> UC_ViewRes & UC_Publish & UC_CreateProj & UC_PrintPapers
    Teacher --> UC_OrderSupport
    Teacher --> UC_ViewBooks & UC_BorrowReturn
    
    EmpRes --> UC_ViewRes & UC_Publish & UC_CreateProj & UC_PrintPapers

    %% Admin & Manager moves
    Admin --> UC_ViewAllUsers & UC_CreateUser & UC_DeleteUser & UC_Logs & UC_TopRes & UC_ManageNews
    Manager --> UC_ViewReq & UC_ProcessReq & UC_CreateCourse & UC_AssignCourse & UC_AddLesson & UC_ManageNews & UC_Stats

    %% Outputs to Secondary Actors (Consumers on the right)
    UC_Complaint -->|Routed to| Dean
    UC_SubmitReq -->|Processed by| Dean
    Dean --> UC_ViewReq & UC_ProcessReq

    UC_OrderSupport -->|Routed to| TechSupport
    TechSupport --> UC_ViewNewOrders & UC_ProcessOrder & UC_FixSys
    
    %% Librarian actions & inputs
    Librarian --> UC_ViewBooks & UC_ManageBooks
    SYS_Notify -->|Alerts| Librarian

    %% System Engine
    System --> SYS_CalcGPA & SYS_CalcHIndex & SYS_CheckLimits & SYS_NewsGen & SYS_Notify & SYS_MsgRouting
```
