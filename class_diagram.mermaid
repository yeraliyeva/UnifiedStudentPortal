            OrderStatus["OrderStatus"]:::enums
            RequestStatus["RequestStatus"]:::enums
            HelpType["HelpType"]:::enums
            PaperFormat["PaperFormat"]:::enums
        end

        subgraph DOM_REPO["Repository Ports / Interfaces  (domain/repository)"]
            direction LR
            UserRepo["«interface» UserRepository"]:::repo
            CourseRepo["«interface» CourseRepository"]:::repo
            BookRepo["«interface» BookRepository"]:::repo
            MessageRepo["«interface» MessageRepository"]:::repo
            NewsRepo["«interface» NewsRepository"]:::repo
            RequestRepo["«interface» RequestRepository"]:::repo
            OrderRepo["«interface» OrderRepository"]:::repo
            PaperRepo["«interface» ResearchPaperRepository"]:::repo
            ProjectRepo["«interface» ResearchProjectRepository"]:::repo
            OrgRepo["«interface» OrganizationRepository"]:::repo
            NotifRepo["«interface» NotificationRepository"]:::repo
            LogRepo["«interface» LogRepository"]:::repo
        end
    end

    %% ════════════════════════════════════════════════════════
    %%   LAYER 4 · INFRASTRUCTURE
    %% ════════════════════════════════════════════════════════
    subgraph INFRA["🔌  INFRASTRUCTURE  (src/infrastructure)"]
        direction TB

        subgraph INF_AUTH["auth"]
            direction LR
            PlainPasswordHasher["PlainPasswordHasher"]:::infra
        end

        subgraph INF_I18N["i18n"]
            direction LR
            Translator["«interface» Translator"]:::iface
            PropertiesTranslator["PropertiesTranslator"]:::infra
        end

        subgraph INF_LOG["logging"]
            direction LR
            Logger["«interface» Logger"]:::iface
            RepositoryLogger["RepositoryLogger"]:::infra
        end

        subgraph INF_JSON["persistence / json  — hand-rolled parser"]
            direction LR
            JsonValue["«sealed» JsonValue"]:::infra
            JsonString["JsonString"]:::infra
            JsonNumber["JsonNumber"]:::infra
            JsonBool["JsonBool"]:::infra
            JsonNull["JsonNull"]:::infra
            JsonArray["JsonArray"]:::infra
            JsonObject["JsonObject"]:::infra
            JsonReader["JsonReader"]:::infra
            JsonWriter["JsonWriter"]:::infra
            JsonObjectBuilder["JsonObjectBuilder"]:::infra
        end

        subgraph INF_DB["persistence / database"]
            direction LR
            DatabaseIf["«interface» Database"]:::iface
            JsonFileDatabase["JsonFileDatabase"]:::infra
        end

        subgraph INF_ORM["persistence / orm  — generic ORM"]
            direction LR
            OrmRepo["Repository&lt;T,ID&gt;"]:::infra
            QueryBuilder["QueryBuilder&lt;T,ID&gt;"]:::infra
            EntityMapper["«interface» EntityMapper&lt;T,ID&gt;"]:::iface
            Condition["Condition"]:::infra
            Op["«enum» Op"]:::infra
            MapperHelpers["MapperHelpers"]:::infra
        end

        subgraph INF_MAP["persistence / mapper"]
            direction LR
            UserMapper["UserMapper"]:::infra
            CourseMapper["CourseMapper"]:::infra
            BookMapper["BookMapper"]:::infra
            MessageMapper["MessageMapper"]:::infra
            NewsMapper["NewsMapper"]:::infra
            RequestMapper["RequestMapper"]:::infra
            OrderMapper["OrderMapper"]:::infra
            PaperMapper["ResearchPaperMapper"]:::infra
            ProjectMapper["ResearchProjectMapper"]:::infra
            OrgMapper["OrganizationMapper"]:::infra
            NotifMapper["NotificationMapper"]:::infra
            LogMapper["LogEntryMapper"]:::infra
        end

        subgraph INF_ORMR["persistence / orm / repository"]
            direction LR
            OrmUserRepo["OrmUserRepository"]:::infra
            OrmCourseRepo["OrmCourseRepository"]:::infra
            OrmBookRepo["OrmBookRepository"]:::infra
            OrmMessageRepo["OrmMessageRepository"]:::infra
            OrmNewsRepo["OrmNewsRepository"]:::infra
            OrmRequestRepo["OrmRequestRepository"]:::infra
            OrmOrderRepo["OrmOrderRepository"]:::infra
            OrmPaperRepo["OrmResearchPaperRepository"]:::infra
            OrmProjectRepo["OrmResearchProjectRepository"]:::infra
            OrmOrgRepo["OrmOrganizationRepository"]:::infra
            OrmNotifRepo["OrmNotificationRepository"]:::infra
            OrmLogRepo["OrmLogRepository"]:::infra
        end

        subgraph INF_MEM["persistence / inmemory  — used in tests"]
            direction LR
            MemUserRepo["InMemoryUserRepository"]:::infra
            MemCourseRepo["InMemoryCourseRepository"]:::infra
            MemBookRepo["InMemoryBookRepository"]:::infra
            MemMsgRepo["InMemoryMessageRepository"]:::infra
            MemNewsRepo["InMemoryNewsRepository"]:::infra
            MemOrderRepo["InMemoryOrderRepository"]:::infra
            MemPaperRepo["InMemoryResearchPaperRepository"]:::infra
            MemProjectRepo["InMemoryResearchProjectRepository"]:::infra
            MemOrgRepo["InMemoryOrganizationRepository"]:::infra
            MemNotifRepo["InMemoryNotificationRepository"]:::infra
            MemLogRepo["InMemoryLogRepository"]:::infra
        end
    end

    %% ════════════════════════════════════════════════════════
    %%   LAYER 5 · DATA STORAGE
    %% ════════════════════════════════════════════════════════
    subgraph DATA["💾  DATA STORAGE  (data/*.json)"]
        direction LR
        usersJ[("users.json")]:::data
        coursesJ[("courses.json")]:::data
        booksJ[("books.json")]:::data
        messagesJ[("messages.json")]:::data
        newsJ[("news.json")]:::data
        requestsJ[("requests.json")]:::data
        ordersJ[("orders.json")]:::data
        papersJ[("research_papers.json")]:::data
        projectsJ[("research_projects.json")]:::data
        orgsJ[("organizations.json")]:::data
        notifsJ[("notifications.json")]:::data
        logsJ[("logs.json")]:::data
    end

    %% ════════════════════════════════════════════════════════
    %%   LAYER INTERCONNECTS  (calling / dependency direction)
    %% ════════════════════════════════════════════════════════

    %% Bootstrap wires everything together
    BOOT -->|"wires"| PRES
    BOOT -->|"wires"| APP
    BOOT -->|"wires"| DOMAIN
    BOOT -->|"wires"| INFRA

    %% CLI calls Application
    PRES -->|"invokes use cases"| APP

    %% Application calls Domain
    APP -->|"uses domain model"| DOMAIN

    %% Infrastructure implements Domain ports
    INFRA -->|"implements repository interfaces"| DOM_REPO

    %% ORM concrete repos implement the port interfaces
    OrmUserRepo -->|"implements"| UserRepo
    OrmCourseRepo -->|"implements"| CourseRepo
    OrmBookRepo -->|"implements"| BookRepo
    OrmMessageRepo -->|"implements"| MessageRepo
    OrmNewsRepo -->|"implements"| NewsRepo
    OrmRequestRepo -->|"implements"| RequestRepo
    OrmOrderRepo -->|"implements"| OrderRepo
    OrmPaperRepo -->|"implements"| PaperRepo
    OrmProjectRepo -->|"implements"| ProjectRepo
    OrmOrgRepo -->|"implements"| OrgRepo
    OrmNotifRepo -->|"implements"| NotifRepo
    OrmLogRepo -->|"implements"| LogRepo

    %% In-memory repos also implement the same ports (test doubles)
    MemUserRepo -.->|"implements"| UserRepo
    MemCourseRepo -.->|"implements"| CourseRepo
    MemPaperRepo -.->|"implements"| PaperRepo
    MemProjectRepo -.->|"implements"| ProjectRepo

    %% ORM stack delegates to JSON database → files
    OrmRepo -->|"reads/writes"| DatabaseIf
    JsonFileDatabase -->|"implements"| DatabaseIf
    JsonFileDatabase -->|"reads/writes"| DATA

    %% Mappers used by ORM repos
    EntityMapper -->|"implemented by"| INF_MAP

    %% Domain services call domain repositories
    DOM_SVC -->|"calls"| DOM_REPO
    DOM_RULES -->|"calls"| DOM_REPO
