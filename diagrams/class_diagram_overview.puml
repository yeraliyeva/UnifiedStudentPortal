@startuml UniversityManagementSystemOverview
' University Management System — Architectural Overview
' Clean Architecture: Presentation → Application → Domain ← Infrastructure
' ~45 key elements — grouped for readability

top to bottom direction

skinparam monochrome false
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam nodesep 40
skinparam ranksep 50
skinparam packageStyle rectangle
skinparam defaultFontName "Arial"
skinparam defaultFontSize 11

skinparam class {
  BackgroundColor #FFFFFF
  BorderColor #8B949E
  FontColor #24292F
  HeaderBackgroundColor #F6F8FA
  AttributeFontColor #57606A
  StereotypeFontColor #0969DA
  ArrowColor #57606A
}
skinparam interface {
  BackgroundColor #DDF4FF
  BorderColor #0969DA
  FontColor #0550AE
  StereotypeFontColor #0969DA
}
skinparam abstract {
  BackgroundColor #FFF8C5
  BorderColor #9A6700
  FontColor #7D4E00
  StereotypeFontColor #9A6700
}
skinparam enum {
  BackgroundColor #DAFBE1
  BorderColor #1A7F37
  FontColor #116329
  StereotypeFontColor #1A7F37
}
skinparam package {
  BackgroundColor #F6F8FA
  BorderColor #D0D7DE
  FontStyle bold
  FontColor #24292F
}
skinparam note {
  BackgroundColor #FFF8C5
  BorderColor #D0D7DE
  FontSize 9
}

' ════════════════════════════════════════════════════════════
'  LAYER 1 — PRESENTATION (CLI)
' ════════════════════════════════════════════════════════════

package "<<Presentation Layer>>" as PL #F0F7FF {

  interface Console {
    +println(line : String) : void
    +readLine(prompt : String) : String
    +readInt(prompt : String) : int
  }

  class LoginScreen {
    -users : UserRepository
    -hasher : PasswordHasher
    -console : Console
    +run() : Optional<User>
  }

  interface Menu {
    +run() : void
  }

  interface MenuFactory {
    +menuFor(user : User) : Menu
  }
}

note bottom of Menu
  <b>9 role-based implementations:</b>
  AdminMenu, StudentMenu,
  GraduateStudentMenu, TeacherMenu,
  DeanMenu, ManagerMenu,
  LibrarianMenu, TechSupportMenu,
  EmployeeResearcherMenu
end note

' ════════════════════════════════════════════════════════════
'  LAYER 2 — BOOTSTRAP (Dependency Injection)
' ════════════════════════════════════════════════════════════

package "<<Bootstrap>>" as BL #F0FFF4 {

  class AppContext {
    +console : Console
    +loginScreen : LoginScreen
    +menuFactory : MenuFactory
    +users : UserRepository
    +courses : CourseRepository
    +books : BookRepository
    +messages : MessageRepository
    +enrollmentService : EnrollmentService
    +paperPublisher : PaperPublisher
    +{static} withJsonStorage(dataDir : Path) : AppContext
  }

  class DefaultMenuFactory implements MenuFactory {
    -ctx : AppContext
    +menuFor(user : User) : Menu
  }

  class DataSeeder {
    -ctx : AppContext
    +seedIfEmpty() : void
  }
}

' ════════════════════════════════════════════════════════════
'  LAYER 3 — APPLICATION (Use Case Orchestration)
' ════════════════════════════════════════════════════════════

package "<<Application Layer>>" as AL #FFFCF0 {

  class "Result<T>" as Result {
    -value : T
    -error : String
    +{static} ok(value : T) : Result<T>
    +{static} fail(error : String) : Result<T>
    +isOk() : boolean
    +value() : T
    +error() : String
  }

  class AdminUseCases <<facade>> {
    +createStudent(...) : Result<Student>
    +createTeacher(...) : Result<Teacher>
    +createGradStudent(...) : Result<GraduateStudent>
    +createDean(...) : Result<Dean>
    +createManager(...) : Result<Manager>
    +createLibrarian(...) : Result<Librarian>
    +createTechSupport(...) : Result<TechSupport>
    +createEmpResearcher(...) : Result<EmployeeResearcher>
    +deleteUser(actor, target) : Result<Void>
    +generateAcademicReport() : String
    +generateTopResearcherNews() : void
  }

  class CourseUseCases <<facade>> {
    +enrollInCourse(student, course) : Result<Void>
    +dropCourse(student, course) : Result<Void>
    +recordMarks(teacher, course, student, ...) : Result<Void>
    +assignTeacher(teacher, course) : Result<Void>
    +createCourse(name, credits, type, cap) : Result<Course>
    +setCourseCapacity(course, max) : Result<Void>
    +setCoursePrerequisite(course, prereq) : Result<Void>
    +addLesson(course, ...) : Result<Void>
    +viewTranscript(student) : String
  }

  class LibraryUseCases <<facade>> {
    +borrowBook(borrower, title) : Result<Void>
    +returnBook(borrower, bookId) : Result<Void>
    +addBook(title, author) : Result<Book>
    +removeBook(bookId) : Result<Void>
  }

  class MessagingUseCases <<facade>> {
    +sendMessage(from, to, ...) : Result<Void>
    +publishNews(author, title, body) : Result<Void>
    +commentOnNews(newsId, comment) : Result<Void>
    +submitRequest(requester, ...) : Result<Void>
    +processRequest(id, status) : Result<Void>
    +createITOrder(requester, desc) : Result<Void>
    +acceptOrder(executor, id) : Result<Void>
    +completeOrder(executor, id) : Result<Void>
  }

  class ResearchUseCases <<facade>> {
    +createResearchProject(supervisor, ...) : Result<ResearchProject>
    +joinResearchProject(participant, ...) : Result<Void>
    +publishPaper(author, ...) : Result<ResearchPaper>
    +subscribeToJournal(researcher, ...) : Result<Void>
    +unsubscribeFromJournal(researcher, ...) : Result<Void>
    +generateCitation(paperId, format) : Result<String>
    +setSupervisor(supervisor, student) : Result<Void>
  }

  class UserUseCases <<facade>> {
    +becomeResearcher(user, field) : Result<Void>
    +rateTeacher(student, teacher, rating) : Result<Void>
    +complainAboutStudent(teacher, student, ...) : Result<Void>
  }
}

note as UCNote
  Each <<facade>> represents a group of
  individual use-case classes, e.g.
  <b>AdminUseCases</b> groups:
  CreateStudent, CreateTeacher,
  DeleteUser, GenerateAcademicReport, ...
  (40+ classes total in src/application/)
end note
UCNote .. AdminUseCases

' ════════════════════════════════════════════════════════════
'  LAYER 4 — DOMAIN (Business Logic)
' ════════════════════════════════════════════════════════════

package "<<Domain Layer>>" as DL #FFF8F0 {

  ' ── User Hierarchy ─────────────────────────────
  package "User Hierarchy" {
    abstract class User {
      -username : Username
      -passwordHash : String
      -name : PersonName
      -gender : Gender
      -email : Email
      -faculty : Faculty
      +changePassword(hash : String) : void
      +changeEmail(email : Email) : void
      +changeLanguage(lang : Language) : void
    }

    class Admin

    class Student {
      -degreeType : DegreeType
      -availableCredits : Credits
      -failCount : int
      -enrolled : Set<CourseId>
      -completed : Set<CourseId>
      +recordEnrollment(id : CourseId, cost : Credits) : void
      +recordDrop(id : CourseId, refund : Credits) : void
      +recordCompletion(id : CourseId) : void
      +hasReachedFailLimit() : boolean
    }

    class GraduateStudent {
      -supervisorUsername : Username
      +supervisor() : Optional<Username>
      +setSupervisor(s : Username) : void
    }

    abstract class Employee {
      -salary : Money
      -hireDate : LocalDate
      -insuranceNumber : String
    }

    class Teacher {
      -degree : String
      -position : TeacherPosition
      -taughtCourses : Set<CourseId>
      -ratings : List<Integer>
      +recordCourseAssignment(id : CourseId) : void
      +addRating(r : int) : void
      +averageRating() : double
    }

    class Dean
  }

  note right of Employee
    <b>Other subtypes:</b>
    Manager, Librarian,
    TechSupport,
    EmployeeResearcher
  end note

  ' ── Capability Interfaces ──────────────────────
  package "Capabilities" {
    interface ResearcherCapable {
      +isResearcher() : boolean
      +activateResearcher(field : String) : void
      +researcherProfile() : ResearcherProfile
    }

    interface BookBorrowerCapable

    class ResearcherProfile {
      -owner : Username
      -field : String
      -subscribedJournals : Set<String>
      +subscribe(journal : String) : void
      +unsubscribe(journal : String) : void
    }
  }

  ' ── Course Aggregate ───────────────────────────
  package "Course Aggregate" {
    class Course {
      -id : CourseId
      -name : String
      -credits : Credits
      -type : DisciplineType
      -capacity : Capacity
      -lessons : List<Lesson>
      -prerequisites : Set<CourseId>
      -grades : Map<Username, Grade>
      +enroll(student : Username) : void
      +unenroll(student : Username) : void
      +isFull() : boolean
      +assignTeacher(teacher : Username) : void
      +addLesson(l : Lesson) : void
      +recordGrade(student : Username, grade : Grade) : void
    }

    class Grade <<record>> {
      +firstHalf : int
      +secondHalf : int
      +exam : int
      +total() : int
      +isPassing() : boolean
      +letter() : String
    }

    class Lesson <<record>> {
      +type : LessonType
      +slot : TimeSlot
      +room : Room
    }
  }

  ' ── Research Aggregate ─────────────────────────
  package "Research Aggregate" {
    class ResearchPaper {
      -id : PaperId
      -title : String
      -author : Username
      -journal : JournalName
      -pages : int
      -doi : String
      -citations : int
      +cite() : void
    }

    class ResearchProject {
      -id : int
      -journal : JournalName
      -topic : String
      -supervisor : Username
      -participants : Set<Username>
      -publishedPapers : List<PaperId>
      +addParticipant(u : Username) : void
      +recordPublication(id : PaperId) : void
    }
  }

  ' ── Other Entities ─────────────────────────────
  package "Other Entities" {
    class Book {
      -id : BookId
      -title : String
      -author : String
      -borrowedBy : Username
      +lendTo(user : Username) : void
      +returnFrom(user : Username) : void
    }

    class Message {
      -sender : Username
      -recipient : Username
      -subject : String
      -urgency : UrgencyLevel
      -status : MessageStatus
      +markRead() : void
    }

    class Organization {
      -name : String
      -head : Username
      -members : Set<Username>
      +addMember(u : Username) : void
    }
  }

  note bottom of Message
    <b>Also includes:</b>
    News, Request, Order,
    Notification, LogEntry
  end note

  ' ── Domain Services ────────────────────────────
  package "Domain Services" {
    class EnrollmentService {
      -rules : List<EnrollmentRule>
      +tryEnroll(student : Student, course : Course) : EnrollmentDecision
    }

    interface EnrollmentRule {
      +check(student : Student, course : Course) : EnrollmentDecision
    }

    class PaperPublisher {
      +publish(paper : ResearchPaper) : void
    }

    class GpaCalculator {
      +of(student : Student) : double
    }

    class HIndexCalculator {
      +calculate(papers : List<ResearchPaper>) : HIndex
    }
  }

  note left of EnrollmentRule
    <b>Chain of Responsibility:</b>
    MaxFailLimitRule,
    AlreadyEnrolledRule,
    CreditLimitRule,
    CapacityRule,
    PrerequisiteRule,
    ScheduleConflictRule
  end note

  ' ── Value Objects ──────────────────────────────
  package "Value Objects" {
    class Username {
      +value : String
    }
    class Credits <<record>> {
      +value : int
      +{static} SEMESTER_LIMIT : Credits
      +covers(required : Credits) : boolean
      +minus(other : Credits) : Credits
    }
    class IdSequence {
      +next() : int
      +seedAtLeast(n : int) : void
    }
  }

  note bottom of Username
    <b>Also includes:</b>
    PersonName, Email, Money,
    CourseId, BookId, PaperId,
    JournalName, Capacity, Room,
    TimeSlot, HIndex
  end note

  ' ── Repository Ports ───────────────────────────
  package "Repository Ports" {
    interface UserRepository {
      +save(user : User) : void
      +findByUsername(username : Username) : Optional<User>
      +exists(username : Username) : boolean
      +delete(username : Username) : void
      +findAll() : Collection<User>
    }

    interface CourseRepository {
      +save(course : Course) : void
      +findById(id : CourseId) : Optional<Course>
      +findAll() : Collection<Course>
    }

    interface BookRepository {
      +save(book : Book) : void
      +findById(id : BookId) : Optional<Book>
      +findFirstAvailableByTitle(title : String) : Optional<Book>
      +findAll() : Collection<Book>
      +delete(id : BookId) : void
    }

    interface ResearchPaperRepository {
      +save(paper : ResearchPaper) : void
      +findById(id : PaperId) : Optional<ResearchPaper>
      +findByAuthor(author : Username) : List<ResearchPaper>
    }
  }

  note bottom of ResearchPaperRepository
    <b>+8 more repository interfaces:</b>
    MessageRepository,
    NewsRepository,
    RequestRepository,
    OrderRepository,
    ResearchProjectRepository,
    OrganizationRepository,
    NotificationRepository,
    LogRepository
  end note
}

' ════════════════════════════════════════════════════════════
'  LAYER 5 — INFRASTRUCTURE (Persistence & I/O)
' ════════════════════════════════════════════════════════════

package "<<Infrastructure Layer>>" as IL #FFF0F0 {

  package "Persistence Engine" {
    interface Database {
      +readTable(name : String) : List<JsonValue>
      +writeTable(name : String, rows : List<JsonValue>) : void
    }

    class JsonFileDatabase implements Database {
      -root : Path
      +readTable(name : String) : List<JsonValue>
      +writeTable(name : String, rows : List<JsonValue>) : void
    }

    interface "EntityMapper<T, ID>" as EntityMapper {
      +toJson(entity : T) : JsonValue
      +fromJson(json : JsonValue) : T
      +idOf(entity : T) : ID
    }

    class "Repository<T, ID>" as OrmRepository {
      -db : Database
      -mapper : EntityMapper<T, ID>
      +save(entity : T) : T
      +find(id : ID) : Optional<T>
      +findAll() : List<T>
      +delete(entity : T) : boolean
      +select() : QueryBuilder<T, ID>
    }
  }

  class OrmUserRepository implements UserRepository {
    -repo : Repository<User, Username>
  }

  class OrmCourseRepository implements CourseRepository {
    -repo : Repository<Course, CourseId>
  }

  note bottom of OrmCourseRepository
    <b>+10 more ORM repositories:</b>
    OrmBookRepository,
    OrmMessageRepository,
    OrmNewsRepository, ...
    <b>+11 InMemory test doubles</b>
    <b>+12 EntityMapper impls</b>
  end note

  interface PasswordHasher {
    +hash(plain : String) : String
    +matches(plain : String, hash : String) : boolean
  }

  class PlainPasswordHasher implements PasswordHasher
}

' ════════════════════════════════════════════════════════════
'  RELATIONSHIPS
' ════════════════════════════════════════════════════════════

' ── Inheritance ──────────────────────────────────────────────
User <|-- Admin
User <|-- Student
User <|-- Employee
Student <|-- GraduateStudent
Employee <|-- Teacher
Teacher <|-- Dean

' ── Interface Realisation ────────────────────────────────────
Student ..|> ResearcherCapable
Student ..|> BookBorrowerCapable
Teacher ..|> ResearcherCapable
Teacher ..|> BookBorrowerCapable

' ── Composition ──────────────────────────────────────────────
User "1" *-- "1" Username                    : username
Student "1" *-- "0..1" ResearcherProfile
Teacher "1" *-- "0..1" ResearcherProfile
Course "1" *-- "1" Credits                   : credits
Course "1" *-- "0..*" Lesson                 : lessons
Course "1" *-- "0..*" Grade                  : grades

' ── Aggregation ──────────────────────────────────────────────
EnrollmentService "1" o-- "1..*" EnrollmentRule : chain
Student "1" o-- "0..*" CourseId               : enrolled
ResearchProject "1" o-- "0..*" PaperId        : papers

' ── Association ──────────────────────────────────────────────
ResearchPaper --> Username                    : author
Book "0..1" --> Username                      : borrowedBy
GraduateStudent "0..1" --> Username            : supervisor
Message --> Username                          : sender / recipient

' ── Dependencies (layer flow) ────────────────────────────────
' Presentation → Bootstrap
LoginScreen ..> AppContext
DefaultMenuFactory ..> AppContext

' Bootstrap → Application (use cases)
AppContext ..> AdminUseCases
AppContext ..> CourseUseCases
AppContext ..> LibraryUseCases
AppContext ..> MessagingUseCases
AppContext ..> ResearchUseCases
AppContext ..> UserUseCases

' Application → Domain Services
CourseUseCases ..> EnrollmentService
CourseUseCases ..> GpaCalculator
ResearchUseCases ..> PaperPublisher
ResearchUseCases ..> HIndexCalculator
AdminUseCases ..> GpaCalculator

' Application → Repository Ports
AdminUseCases ..> UserRepository
CourseUseCases ..> CourseRepository
LibraryUseCases ..> BookRepository
ResearchUseCases ..> ResearchPaperRepository

' Domain Services → Repository Ports
PaperPublisher ..> ResearchPaperRepository
GpaCalculator ..> CourseRepository
EnrollmentService ..> CourseRepository

' Repository Ports → Domain Entities
UserRepository ..> User
CourseRepository ..> Course
BookRepository ..> Book
ResearchPaperRepository ..> ResearchPaper

' Infrastructure → Domain Ports (Dependency Inversion)
OrmRepository ..> Database
OrmRepository ..> EntityMapper
OrmUserRepository ..> OrmRepository
OrmCourseRepository ..> OrmRepository
LoginScreen ..> PasswordHasher

' ── Enums (grouped) ─────────────────────────────────────────
note as EnumNote
  <b>15 Enumerations:</b>
  DegreeType, Faculty, Gender, Language,
  TeacherPosition, ManagerPosition,
  DisciplineType, LessonType, WeekDay,
  MessageStatus, UrgencyLevel, OrderStatus,
  RequestStatus, HelpType, PaperFormat
end note
EnumNote .. User

@enduml
